    <stack>
      <ol marker="A">
        <li><m>\frac{1}{2}</m> es equivalente a <m>\frac{3}{6}</m></li>
        <li><m>\frac{1}{2}</m> es equivalente a <m>\frac{1}{3}</m></li>
        <li><m>\frac{2}{2}</m> es equivalente a <m>\frac{4}{4}</m></li>
        <li><m>\frac{2}{2}</m> es equivalente a <m>\frac{6}{6}</m></li>
        <li><m>\frac{2}{3}</m> es equivalente a <m>\frac{4}{6}</m></li>
        <li><m>\frac{2}{3}</m> es equivalente a <m>\frac{3}{4}</m></li>
      </ol>
    </stack>
