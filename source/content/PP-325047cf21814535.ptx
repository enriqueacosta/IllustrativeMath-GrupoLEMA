<!-- <title>Previo a la unidad</title> -->
<!-- <title>Exploración</title> -->
<!-- <title component="metadata">Alineado con <xref ref="graVV-uniYY-secZZ" text="title"/></title> -->
<title component="metadata">Alineado con <xref ref="lec-VVVVVV" text="title"/></title>

<statement>
  <ol>
    <li>
      <sidebyside>
        <p>¿Qué fracción del rectángulo está sombreada?</p>
        <image source="svg-source/tikz-file-151725">
          <shortdescription>Diagram. Rectangle partitioned into 6 equal parts, one of them shaded.</shortdescription>
        </image>
      </sidebyside>
    </li>
    <li>
      <sidebyside>
        <stack>
          <p>Parte el rectángulo en 8 partes iguales.</p>
          <p>¿Qué fracción de todo el rectángulo está representada por cada parte?</p>
        </stack>
          <image source="svg-source/tikz-file-151726">
            <shortdescription>Diagram. Rectangle.</shortdescription>
        </image>
      </sidebyside>
    </li>
  </ol>
</statement>

<solution>
  <p>[++++++++++++++++++++]</p>
  <ol>
    <li>
      <p><m>\frac{1}{6}</m></p>
    </li>
    <li>
      <p><m>\frac{1}{8}</m></p>
    </li>
  </ol>
  <image source="svg-source/tikz-file-152484">
    <shortdescription>Diagram.</shortdescription>
  </image>
</solution>

</exercise>
