<title>Previo a la unidad</title>
<!-- <title>Exploración</title> -->
<!-- <title component="metadata">Alineado con <xref ref="graVV-uniYY-secZZ" text="title"/></title> -->
<!-- <title component="metadata">Alineado con <xref ref="lec-VVVVVV" text="title"/></title> -->

<statement>
  <p>Llena cada espacio en blanco con un <m>\lt</m> o un <m>\gt</m> para comparar los números.</p>
  <ol cols="3">
    <li>
      <p><m>718\, \underline{\hspace{1cm}}\, 817</m></p>
    </li>
    <li>
      <p><m>106\, \underline{\hspace{1cm}} \,89</m></p>
    </li>
    <li>
      <p><m>806\, \underline{\hspace{1cm}} \,809</m></p>
    </li>
  </ol>
</statement>

<solution>
  <p>[++++++++++++++++++++]</p>
  <ol>
    <li>
      <p><m>\lt</m></p>
    </li>
    <li>
      <p><m>\gt</m></p>
    </li>
    <li>
      <p><m>\lt</m></p>
    </li>
  </ol>
</solution>

</exercise>
