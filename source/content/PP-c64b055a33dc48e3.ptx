<!-- <title>Previo a la unidad</title> -->
<!-- <title>Exploración</title> -->
<!-- <title component="metadata">Alineado con <xref ref="graVV-uniYY-secZZ" text="title"/></title> -->
<title component="metadata">Alineado con <xref ref="lec-VVVVVV" text="title"/></title>

<statement>
  <ol>
    <li>
      <p>Ubica y marca <m>\frac{1}{4}</m> en la recta numérica. Explica tu razonamiento.</p>
      <image source="svg-source/tikz-file-151735">
        <shortdescription>Number line. Five evenly spaced tick marks, 0 and 1 labeled. First tick mark, 0. Last tick mark, 1.</shortdescription>
      </image>
    </li>
    <li>
      <p>Ubica y marca <m>\frac{1}{6}</m> en la recta numérica. Explica tu razonamiento.</p>
      <image source="svg-source/tikz-file-151736">
        <shortdescription>Number line. Tick marks labeled zero and one with unlabeled tick marks between.</shortdescription>
      </image>
    </li>
  </ol>
</statement>

<solution>
  <p>[++++++++++++++++++++]</p>
  <ol>
    <li>
      <p>Sample response: It is <m>\frac{1}{4}</m> because there are 4 equal parts and it's the first tick.</p>
      <image source="svg-source/tikz-file-152489">
        <shortdescription>Number line.</shortdescription>
      </image>
    </li>
    <li>
      <p>It is <m>\frac{1}{6}</m> because there are 6 equal parts and it's the first tick.</p>
      <image source="svg-source/tikz-file-152490">
        <shortdescription>Number line.</shortdescription>
      </image>
    </li>
  </ol>
</solution>

</exercise>
