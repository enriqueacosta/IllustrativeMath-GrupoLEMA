<activity xml:id="act-aproximadamente100CercaDe100" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>[@@@@@@@@@]</title>

<statement>
  <p>[@@@@@@@@@]</p>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <ol>
      <li><p>Sample response:

</p><p>[@@@@@@@@] WARNING: Table present.</p><table border="1">
<thead>
<tr>
<th scope="col" style="text-align:center">about 100</th>
<th scope="col" style="text-align:center">not about 100</th>
</tr>
</thead>
<tbody>
<tr>
<td style="text-align:center">94, 109</td>
<td style="text-align:center">163, 36, 13, 216, 52</td>
</tr>
</tbody>
</table>
      </li>
      <li><p>Sample response:

</p><p>[@@@@@@@@] WARNING: Table present.</p><table border="1">
<thead>
<tr>
<th scope="col" style="text-align:center">close to 0</th>
<th scope="col" style="text-align:center">close to 100</th>
<th scope="col" style="text-align:center">close to 200</th>
</tr>
</thead>
<tbody>
<tr>
<td style="text-align:center">13</td>
<td style="text-align:center">94, 109</td>
<td style="text-align:center">216</td>
</tr>
</tbody>
</table><p>Numbers that don’t belong in any column: 36, 52, 163</p>
      </li>
    </ol>
  </solution>


