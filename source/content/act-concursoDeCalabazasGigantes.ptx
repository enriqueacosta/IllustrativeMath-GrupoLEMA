<?xml version='1.0' encoding='utf-8'?>

<activity xml:id="act-concursoDeCalabazasGigantes" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>[@@@@@@@@@]</title>

<statement>
  <p>[@@@@@@@@@]</p>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <p>Sample responses:</p>
<ul>
      <li>How tall is each pumpkin?</li>
      <li>How much does each pumpkin weigh?</li>
      <li>How much wider is the pumpkin on right than the pumpkin on the left?</li>
      <li>How many seeds are in each pumpkin?</li>
    </ul>
  </solution>


