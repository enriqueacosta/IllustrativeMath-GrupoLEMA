<activity xml:id="act-cualDiferente-particiones" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>[@@@@@@@@@]</title>

<statement>
  <p>[@@@@@@@@@]</p>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <p>Sample responses:</p>
<ul>
      <li><p>2 parts: A, E, F, C, and I 3 parts: G, H, J, and K 4 parts: B, D, and L</p></li>
    </ul>
<ul>
      <li><p>Equal parts: A, B, D, E, F, G, J, K, and L Non-equal parts: C, H, and I</p></li>
    </ul>
  </solution>


