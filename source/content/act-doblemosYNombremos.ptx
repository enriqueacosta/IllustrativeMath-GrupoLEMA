<?xml version='1.0' encoding='utf-8'?>

<activity xml:id="act-doblemosYNombremos" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>[@@@@@@@@@]</title>

<statement>
  <p>[@@@@@@@@@]</p>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <p>Sample response:</p>
<ul>
      <li>Students fold the rectangle in half, then fold it in half again to make four equal parts. Students fold a rectangle into three equal parts, then fold the thirds in half to make six equal parts.</li>
    </ul>
  </solution>


