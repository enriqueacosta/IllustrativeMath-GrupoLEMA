  <!-- Tiempo recomendado -->
  <paragraphs>
    <title><custom ref="recommended-time-titulo"/></title>
    <p>10 minutos</p>
  </paragraphs>

  <!-- Introducción de la actividad -->
  <paragraphs>
    <title><custom ref="narrative-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <p>The purpose of this activity is for students to see that they can start adding from the largest place-value unit or from the smallest and still get the same sum. This understanding prepares students to use the standard algorithm for addition, which calls for starting with the ones.</p>
  </paragraphs>


  <!-- Materiales requeridos de la actividad -->
  <paragraphs>
    <title><custom ref="materials-actividad-titulo"/></title>
    <p>[mmmmmmmmmm]</p>
    <!-- si hay materiales, crear los archivos -mat.ptx (para materiales de la actividad) y -matCentros.ptx (para mencionar los otros centros que se usan y para los que se necesitan materiales) y poner los materiales ahí usando los archivos de template. Después hacer xinclude  de estos archivos en la lista de materiales de la lección.-->
    <!-- <xi:include href="./act-dosManerasDeSumar-mat.ptx"/>  -->
    <!-- <xi:include href="./act-dosManerasDeSumar-matCentros.ptx"/>  -->
  </paragraphs>

  <!-- Launch -->
  <paragraphs>
    <title><custom ref="launch-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>Groups of 2</li>
      <li>
        <q>Por un minuto, miren el trabajo de Andre y el trabajo de Clare. Piensen en qué se parecen y en qué son diferentes</q>
      </li>
      <li>1 minute: quiet think time</li>
    </ul>
  </paragraphs>


  <!-- Instrucciones para el desarrollo de la actividad -->
  <paragraphs>
    <title><custom ref="instructions-teacher-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>
        <q>Hablen en parejas sobre en qué se parecen y en qué se diferencian el trabajo de Clare y el trabajo de Andre</q>
      </li>
      <li>3-5 minutes: partner discussion</li>
    </ul>
  </paragraphs>

</prelude>


