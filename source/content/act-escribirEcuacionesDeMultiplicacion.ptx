    <title><custom ref="ccss-actividad-titulo"/></title> 
    <ul>
      <li> 
        <custom ref="ccss-addressing"/>
        <xref ref="ccss-3-OA-A-1" text="custom">3.OA.A.1</xref>,
        <xref ref="ccss-3-OA-A-3" text="custom">3.OA.A.3</xref>
      </li>
    </ul>
  </paragraphs>

  <!-- Tiempo recomendado -->
  <paragraphs>
    <title><custom ref="recommended-time-titulo"/></title>
    <p>15 minutos</p>
  </paragraphs>

  <!-- Introducción de la actividad -->
  <paragraphs>
    <title><custom ref="narrative-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <p>The purpose of this activity is for students to write equations that match situations and diagrams. Students use what they learned in the last activity to use multiplication equations to represent situations and diagrams. In the lesson synthesis, use the words factor and product to help students connect the vocabulary to the concepts.</p>
  </paragraphs>


  <!-- Materiales requeridos de la actividad -->
  <paragraphs>
    <title><custom ref="materials-actividad-titulo"/></title>
    <p>[@@@@@@@@@@@@@@]</p>
