<activity xml:id="act-masDeUnNombre" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>[@@@@@@@@@]</title>

<statement>
  <p>[@@@@@@@@@]</p>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <ol>
      <li><ol>
<li><m>\frac{4}{6}, \frac{2}{3}</m></li>
<li><m>\frac{2}{8}, \frac{1}{4}</m></li>
<li>
<m>\frac{4}{4}, \frac{8}{8}, \frac{2}{2}</m>. Students may also say <m>\frac{3}{3}</m> and <m>\frac{6}{6}</m>.</li>
</ol>
      </li>
      <li><ol>
<li><m>\frac{3}{2}</m></li>
<li><m>\frac{6}{4}, \frac{12}{8}, \frac{9}{6}</m></li>
</ol>
      </li>
    </ol>
  </solution>


