<postlude component="profesor">

  <!-- Estrategias de apoyo para estudiantes con dificultades -->
  <paragraphs>
    <title><custom ref="support-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <p>=== NOT PRESENT ===</p>
  </paragraphs>


  <!-- Síntesis de la actividad -->
  <paragraphs>
    <title><custom ref="synthesis-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>Invite students to display their partitioned strips. Keep a full set of fraction strips displayed.</li>
      <li>Ask previously identified students to share how they fold their strips to get 4, 6, and 8 equal parts.</li>
      <li>If not apparent from students' explanations, highlight that fourths, sixths, and eighths can be found by partitioning each half, third, and fourth, respectively, into two equal parts.</li>
    </ul>
  </paragraphs>


  <!-- Descripción del desarrollo de lenguaje matemático -->
