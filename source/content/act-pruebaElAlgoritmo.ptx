<activity xml:id="act-pruebaElAlgoritmo" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>[@@@@@@@@@]</title>

<statement>
  <p>[@@@@@@@@@]</p>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <ol>
      <li>124 or <m>100 + 20 + 4</m></li>
      <li>233 or <m>200 + 30 + 3</m></li>
      <li>174 or <m>100 + 70 +4</m></li>
      <li>463 or <m>400 + 60 +3</m></li>
      <li><p>257, or an algorithm showing <m>200 + 50 + 7</m></p><p>[@@@@@@@@] WARNING: Fix Image.</p><img alt="Subtraction." role="image" src="../../../../../../figures/tikz-file-147729.svg"/><p>[@@@@@@@@] WARNING: Fix Image.</p><img alt="Expand image" src="../../../../../assets/expand-9ef5655e2d1b5ba286de1390c97f4243f15e264c89106027f5d071073ab562bb.png" title="Expand image"/><p>[@@@@@@@@] WARNING: Fix Image.</p><img alt="Subtraction." role="image" src="../../../../../../figures/tikz-file-147729.svg" width="80%"/></li>
    </ol>
  </solution>


