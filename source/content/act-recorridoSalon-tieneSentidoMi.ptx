<?xml version='1.0' encoding='utf-8'?>

<activity xml:id="act-recorridoSalon-tieneSentidoMi" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>[@@@@@@@@@]</title>

<statement>
  <p>[@@@@@@@@@]</p>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <ol>
      <li>Situation A: 203 beads Situation D: 295 paper clips Situation G: 285 crayons Situation I: 332 baseball cards Situation J: 165 beads</li>
      <li>No response required.</li>
      <li> Sample response: I estimated the answer to be about 325 since <m>225 + 30 + 70 = 325</m>, so your answer makes sense. </li>
    </ol>
  </solution>


