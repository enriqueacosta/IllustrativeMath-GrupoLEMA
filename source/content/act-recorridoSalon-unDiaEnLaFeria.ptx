  <!-- Launch -->
  <paragraphs>
    <title><custom ref="launch-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>Groups of 2</li>
    </ul>
  </paragraphs>


  <!-- Instrucciones para el desarrollo de la actividad -->
  <paragraphs>
    <title><custom ref="instructions-teacher-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>Have half the students stand at their poster with their partner to share their ideas or answer questions as the other students visit their posters.</li>
      <li>Have the other half of the class visit their classmates’ posters with their partner.</li>
      <li>5 minutes: partner work time</li>
      <li>Switch student roles and repeat.</li>
    </ul>
  </paragraphs>

</prelude>


