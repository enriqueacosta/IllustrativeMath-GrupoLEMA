<?xml version='1.0' encoding='utf-8'?>

<activity xml:id="act-todoSobreLasRamas" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>[@@@@@@@@@]</title>

<statement>
  <p>[@@@@@@@@@]</p>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <ol>
      <li>19 twigs</li>
      <li>2 twigs</li>
      <li>4 twigs</li>
      <li>12 twigs</li>
      <li><m>4\frac{3}{4}</m> inches</li>
      <li><m>7\frac{1}{2}</m> inches or <m>7\frac{2}{4}</m> inches</li>
      <li><m>6\frac{1}{4}</m> inches</li>
      <li>Students add an x at <m>3\frac{1}{4}</m>, <m>3\frac{1}{2}</m>, or <m>3\frac{3}{4}</m> and name the corresponding length.</li>
    </ol>
  </solution>


