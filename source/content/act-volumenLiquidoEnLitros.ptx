<?xml version='1.0' encoding='utf-8'?>

<activity xml:id="act-volumenLiquidoEnLitros" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>[@@@@@@@@@]</title>

<statement>
  <p>[@@@@@@@@@]</p>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <p>Sample responses:</p>
<ul>
      <li>Too low: 1–5</li>
      <li>About right: 5–20</li>
      <li>Too high: 20 or higher</li>
    </ul>
  </solution>


