<!-- ============================================================== 
   Notas profesor <postlude> (se pueden mostrar después del enunciado)                      
===================================================================  -->
<postlude component="profesor"> 

  <!-- Posibles errores -->
  <paragraphs>
    <title><custom ref="errores-cool-titulo"/></title><p>[++++++++++++++++]</p>
    <p>Students do not use <m>\frac{1}{6}</m> or partition the interval between 0 and <m>\frac{7}{6}</m> into 7 equal parts to 1.</p>
  </paragraphs>


  <!-- Estrategia de apoyo si muchos estudiantes respondieron incorrectamente -->
  <paragraphs>
    <title><custom ref="apoyo-cool-titulo"/></title><p>[++++++++++++++++]</p>
    <p>Before the warm-up, pass back the cool down and work in small groups to make corrections.</p>
  </paragraphs>

</postlude>

</project>