<?xml version='1.0' encoding='utf-8'?>

<!-- ========================================================== 
  El cool-down es un <project> 
  (distinto a las otras actividades y a los Practice Problems)
===============================================================  -->
<project xml:id="cool-aproximadamenteUnKilogramo" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>Aproximadamente un kilogramo</title>

<statement>
  <p>Selecciona <alert>todos</alert> los objetos que podrían tener un peso de aproximadamente un kilogramo.</p>
  <ol marker="A.">
    <li>
      <p>una bicicleta</p>
    </li>
    <li><p>un libro</p></li>
    <li><p>una canica</p></li>
    <li><p>un lápiz</p></li>
    <li><p>un racimo de bananos</p></li>
  </ol>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <p>B and E</p>
  </solution>


<!-- ============================================================== 
   Notas profesor <prelude> (se pueden mostrar previo al enunciado)                      
===================================================================  -->
<prelude component="profesor">
  <!-- Estándares CCSS asociados -->
  <paragraphs>
    <title><custom ref="ccss-actividad-titulo"/></title> 
    <ul>
      <li> 
        <custom ref="ccss-addressing"/>
        <xref ref="ccss-3-MD-A-2" text="custom">3.MD.A.2</xref>
      </li>
    </ul>
  </paragraphs>
</prelude>


<!-- ============================================================== 
   Notas profesor <postlude> (se pueden mostrar después del enunciado)                      
===================================================================  -->
<postlude component="profesor"> 

  <!-- Posibles errores -->
  <paragraphs>
    <title><custom ref="errores-cool-titulo"/></title><p>[++++++++++++++++]</p>
    <p>Students select objects whose weight is not about a kilogram.</p>
  </paragraphs>


  <!-- Estrategia de apoyo si muchos estudiantes respondieron incorrectamente -->
  <paragraphs>
    <title><custom ref="apoyo-cool-titulo"/></title><p>[++++++++++++++++]</p>
    <p>Before the warm-up, invite students to work in small groups to discuss a correct response to this cool-down.</p>
  </paragraphs>

</postlude>

</project>