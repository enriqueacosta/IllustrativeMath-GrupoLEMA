<project xml:id="cool-completaElDiagramaDePuntos" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>Completa el diagrama de puntos</title>

<statement>
  <p>La lista muestra longitudes de hojas, en pulgadas. Usa las medidas para completar el diagrama de puntos.</p>
  <sidebyside>
    <p><m>2\frac{3}{4}</m></p>
    <p><m>3</m></p>
    <p><m>2</m></p>
    <p><m>3\frac{1}{4}</m></p>
    <p><m>4\frac{1}{2}</m></p>
    <p><m>3\frac{1}{4}</m></p>
    <p><m>2\frac{3}{4}</m></p>
    <p><m>2\frac{1}{2}</m></p>
  </sidebyside>
  <image source="svg-source/tikz-file-180428">
   <shortdescription>diagrama de puntos vacío, de longitud de las hojas en pulgadas</shortdescription>
  </image>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <image source="svg-source/tikz-file-134790">
      <shortdescription>diagrama de puntos diligenciado, de longitud de las hojas en pulgadas</shortdescription>
    </image>
</solution>


