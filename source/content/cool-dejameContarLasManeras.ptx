<!-- ========================================================== 
  El cool-down es un <project> 
  (distinto a las otras actividades y a los Practice Problems)
===============================================================  -->
<project xml:id="cool-dejameContarLasManeras" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>Déjame contar las maneras</title>

<statement>
  <p>Selecciona <alert>todas</alert> las maneras en las que puedes representar doscientos cincuenta y siete.</p>
  <ol>
    <li><p><m>572</m></p></li>
    <li><p><m>257</m></p></li>
    <li><p><m>200 + 50 + 7</m></p></li>
    <li><p><m>20 + 500 + 7</m></p></li>
    <li><p><m>200 + 40 + 17</m></p></li>
    <li><p><m>100 + 140 + 7</m></p></li>
  </ol>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <p>(b), (c), and (e)</p>
  </solution>


<!-- ============================================================== 
   Notas profesor <prelude> (se pueden mostrar previo al enunciado)                      
===================================================================  -->
<prelude component="profesor">
  <!-- Estándares CCSS asociados -->
  <paragraphs>
    <title><custom ref="ccss-actividad-titulo"/></title> 
    <ul>
      <li>
        <custom ref="ccss-buildingTowards"/>
        <xref ref="ccss-2-NBT-A-2" text="custom">2.NBT.A.2</xref>
      </li>
    </ul>
  </paragraphs>
</prelude>


<!-- ============================================================== 
   Notas profesor <postlude> (se pueden mostrar después del enunciado)                      
===================================================================  -->
<postlude component="profesor"> 

  <!-- Posibles errores -->
  <paragraphs>
    <title><custom ref="errores-cool-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <p>Students do not select all the ways that they can represent two hundred fifty-seven.</p>
  </paragraphs>


  <!-- Estrategia de apoyo si muchos estudiantes respondieron incorrectamente -->
  <paragraphs>
    <title><custom ref="apoyo-cool-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <p>Before the warm-up, have students discuss different ways that 257 can be decomposed using place value.</p>
  </paragraphs>

</postlude>

</project>