<!-- ========================================================== 
  El cool-down es un <project> 
  (distinto a las otras actividades y a los Practice Problems)
===============================================================  -->
<project xml:id="cool-deportesFavoritos" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>Deportes favoritos</title>

<statement>
  <sidebyside widths="40% 60%">
  <stack>
  <p>A un grupo de estudiantes le preguntaron: “¿Cuál es tu deporte favorito?”.</p>
 <p>Sus respuestas se muestran en esta gráfica de barras:</p> 
  </stack>
  <image source="svg-source/tikz-file-174487">
        <shortdescription>grafico de barras sobre deportes favoritos</shortdescription>
      </image>  
  </sidebyside>
 <p>Usa la gráfica para responder las preguntas.</p>
 <ol>
  <li>
    <p>
  ¿Cuántos estudiantes más escogieron fútbol que fútbol americano? Muestra cómo pensaste. Usa expresiones o ecuaciones.    
    </p>
  </li>
  <li>
    <p>
  ¿Cuántos estudiantes menos escogieron hockey que baloncesto? Muestra cómo pensaste. Usa expresiones o ecuaciones.    
    </p>
  </li>
 </ol>

</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <ol>
      <li>33 students. Sample response: <m>28 + 2 = 30</m>, <m>30 + 31 = 61</m>, and <m>2 + 31 = 33</m>.</li>
      <li>13 students. Sample response: <m>35-22 = 13</m></li>
    </ol>
  </solution>


<!-- ============================================================== 
   Notas profesor <prelude> (se pueden mostrar previo al enunciado)                      
===================================================================  -->
<prelude component="profesor">
 
</prelude>


