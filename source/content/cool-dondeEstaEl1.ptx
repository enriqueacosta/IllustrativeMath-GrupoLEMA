===============================================================  -->
<project xml:id="cool-dondeEstaEl1" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>¿Dónde está el 1?</title>

<statement>
  <sidebyside widths="40% 55%">
    <p>Ubica y marca el 1 en la recta numérica. Explica cómo razonaste.</p>
    <image source="svg-source/tikz-file-151161">
      <shortdescription>recta numérica con 0 y 1/3 marcados</shortdescription>
    </image>
  </sidebyside>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <sidebyside widths="40% 55%">
      <p>I repeated the <m>\frac{1}{3}</m> space 3 times since there are 3 one-thirds in 1.</p>
      <image source="svg-source/tikz-file-151162">
        <shortdescription>recta numérica con 0, 1/3 y 1 marcados</shortdescription>
      </image>
    </sidebyside>
</solution>


