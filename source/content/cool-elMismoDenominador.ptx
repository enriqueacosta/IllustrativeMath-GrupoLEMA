<!-- ========================================================== 
  El cool-down es un <project> 
  (distinto a las otras actividades y a los Practice Problems)
===============================================================  -->
<project xml:id="cool-elMismoDenominador" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>El mismo denominador</title>

<statement>
  <ol>
    <li>
      <p>
        ¿Qué fracción es mayor: <m>\frac{7}{8}</m> o <m>\frac{6}{8}</m>? Explica o muestra tu razonamiento.
      </p>
    </li>
    <li>
      <p>Usa el símbolo <m>&gt;</m> o el símbolo <m>&lt;</m> para que la afirmación sea verdadera.</p>
      <md>
        \frac{7}{8} <fillin characters="5" /> \frac{6}{8}
      </md>
      
    </li>
  </ol>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <ol>
      <li><m>\frac{7}{8}</m> is greater. Sample response: Seven one-eighth parts are more than 6 one-eighth parts.</li>
      <li><p><m>&gt;</m></p></li>
    </ol>
  </solution>


<!-- ============================================================== 
   Notas profesor <prelude> (se pueden mostrar previo al enunciado)                      
===================================================================  -->
