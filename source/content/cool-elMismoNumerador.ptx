<!-- ========================================================== 
  El cool-down es un <project> 
  (distinto a las otras actividades y a los Practice Problems)
===============================================================  -->
<project xml:id="cool-elMismoNumerador" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>El mismo numerador</title>

<statement>
  <p>Usa el símbolo <m>\gt</m> o el símbolo <m>\lt</m> para que la afirmación sea verdadera. Explica o muestra tu razonamiento.</p>
  <md>
    \frac{4}{3} <fillin characters="2" /> \frac{4}{6}
  </md>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <p><m>\gt</m>. Sample response: Thirds are larger than sixths, so 4 thirds is greater than 4 sixths.</p>
  </solution>


