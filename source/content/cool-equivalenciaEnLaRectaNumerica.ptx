   Notas profesor <postlude> (se pueden mostrar después del enunciado)                      
===================================================================  -->
<postlude component="profesor"> 

  <!-- Posibles errores -->
  <paragraphs>
    <title><custom ref="errores-cool-titulo"/></title><p>[++++++++++++++++]</p>
    <p>Students correctly locate <m>\frac{3}{4}</m> and <m>\frac{6}{8}</m> on each number line, but their lack of precision causes them to say that <m>\frac{3}{4}</m> and <m>\frac{6}{8}</m> are not equal.</p>
  </paragraphs>


  <!-- Estrategia de apoyo si muchos estudiantes respondieron incorrectamente -->
  <paragraphs>
    <title><custom ref="apoyo-cool-titulo"/></title><p>[++++++++++++++++]</p>
    <p>During the launch of the next day's activity, have students brainstorm ways to partition number lines so that each part is the same size.</p>
  </paragraphs>

</postlude>

</project>