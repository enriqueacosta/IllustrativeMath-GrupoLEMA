<?xml version='1.0' encoding='utf-8'?>

<!-- ========================================================== 
  El cool-down es un <project> 
  (distinto a las otras actividades y a los Practice Problems)
===============================================================  -->
<project xml:id="cool-escribeUnaExpresion" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>Escribe una expresión</title>

<statement>
  <p>Había 6 sobres. En cada sobre había 2 notas.</p>
  <p>Escribe una expresión de multiplicación que represente la situación. Explica o muestra tu razonamiento. Haz un dibujo o un diagrama si te ayuda.</p>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <p><m>6\times2</m> or <m>2\times6</m>. The 6 represents the 6 envelopes. The 2 represents the 2 notes in each envelope.</p>
  </solution>


<!-- ============================================================== 
   Notas profesor <prelude> (se pueden mostrar previo al enunciado)                      
===================================================================  -->
<prelude component="profesor">
  <!-- Estándares CCSS asociados -->
  <paragraphs>
    <title><custom ref="ccss-actividad-titulo"/></title> 
    <ul>
      <li>
        <custom ref="ccss-addressing"/>
        <xref ref="ccss-3-OA-A-1" text="custom">3.OA.A.1</xref>
      </li>
    </ul>
  </paragraphs>
</prelude>


<!-- ============================================================== 
   Notas profesor <postlude> (se pueden mostrar después del enunciado)                      
===================================================================  -->
<postlude component="profesor"> 

  <!-- Posibles errores -->
  <paragraphs>
    <title><custom ref="errores-cool-titulo"/></title>
    <p>
      [+++++++++++++++++++++]
    </p>
    <p>Students draw 2 groups of 6.</p>
  </paragraphs>


  <!-- Estrategia de apoyo si muchos estudiantes respondieron incorrectamente -->
  <paragraphs>
    <title><custom ref="apoyo-cool-titulo"/></title>
    <p>
      [++++++++++++++++++++++]
    </p>
    <p>Use the next day's warm-up to have students practice differentiating the groups in the image from the number of dots in each group.</p>
  </paragraphs>

</postlude>

</project>