<project xml:id="cool-hazParticionesDeUnRectangulo" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>Haz particiones de un rectángulo</title>

<statement>
  <sidebyside>
    <p>
      Parte el rectángulo en octavos.
    </p>
    <image source="svg-source/tikz-file-151148">
      <shortdescription>rectángulo</shortdescription>
    </image>
  </sidebyside>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <p>Any drawing that shows 8 equal parts is acceptable.</p>
    <sidebyside>
      <p>
        Sample responses:
      </p>
      <image source="svg-source/tikz-file-151149">
        <shortdescription>rectángulo dividido en 2 filas de cuatro partes iguales cada una.</shortdescription>
      </image>
      <image source="svg-source/tikz-file-151150">
        <shortdescription>rectángulo dividido en 8 tiras verticales del mismo tamaño.</shortdescription>
      </image>
    </sidebyside>
  </solution>


