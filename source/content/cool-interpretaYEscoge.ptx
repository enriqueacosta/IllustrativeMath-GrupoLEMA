<project xml:id="cool-interpretaYEscoge" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>Interpreta y escoge</title>

<statement>
  <p>Selecciona <alert>todas</alert> las afirmaciones que son verdaderas sobre las medidas que muestra el diagrama de puntos.</p>
  <image source="svg-source/tikz-file-180427">
   <shortdescription>diagrama de puntos de longitud de hojas en pulgadas</shortdescription>
  </image>
  <ol marker="A">
    <li>
      <p>Cinco hojas tenían una longitud de <m>6\frac{1}{2}</m> pulgadas.</p>
    </li>
    <li>
      <p>Seis hojas tenían una longitud de <m>9\frac{1}{2}</m> pulgadas.</p>
    </li>
    <li>
      <p>12 hojas fueron medidas.</p>
    </li>
    <li>
      <p>20 hojas fueron medidas.</p>
    </li>
    <li>
      <p>La hoja más corta medía 5 pulgadas.</p>
    </li>
    <li>
      <p>La hoja más corta medía <m>4\frac{1}{2}</m> pulgadas.</p>
    </li>
  </ol>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <p>A, D, F</p>
  </solution>


