<!-- ========================================================== 
  El cool-down es un <project> 
  (distinto a las otras actividades y a los Practice Problems)
===============================================================  -->
<project xml:id="cool-laFraccionSombreada" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>La fracción sombreada</title>

<statement>
  <p>El rectángulo representa 1 unidad. ¿Qué fracción está sombreada? Explica tu razonamiento.</p>
  <image source="svg-source/tikz-file-151155">
    <shortdescription>rectángulo dividido en sextos, con 5 partes sombreadas.</shortdescription>
  </image>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <p><m>\frac{5}{6}</m>. Sample response: The rectangle is split into 6 equal parts and 5 of the one-sixth parts are shaded.</p>
  </solution>


<!-- ============================================================== 
   Notas profesor <prelude> (se pueden mostrar previo al enunciado)                      
===================================================================  -->
<prelude component="profesor">
  <!-- Estándares CCSS asociados -->
