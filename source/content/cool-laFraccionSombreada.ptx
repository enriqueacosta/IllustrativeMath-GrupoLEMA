<!-- ============================================================== 
   Notas profesor <postlude> (se pueden mostrar después del enunciado)                      
===================================================================  -->
<postlude component="profesor"> 

  <!-- Posibles errores -->
  <paragraphs>
    <title><custom ref="errores-cool-titulo"/></title><p>[++++++++++++++++]</p>
    <p>Students answer with the unit fraction that represents each part rather than the fraction that represents the entire shaded portion.</p>
  </paragraphs>


  <!-- Estrategia de apoyo si muchos estudiantes respondieron incorrectamente -->
  <paragraphs>
    <title><custom ref="apoyo-cool-titulo"/></title><p>[++++++++++++++++]</p>
    <p>Before the warm-up, pass back the cool down and have students discuss how <m>\frac{5}{6}</m> represents the shaded portion of the rectangle.</p>
  </paragraphs>

</postlude>

</project>