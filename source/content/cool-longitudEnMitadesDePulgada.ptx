===============================================================  -->
<project xml:id="cool-longitudEnMitadesDePulgada" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>Longitud en mitades de pulgada</title>

<statement>
  <p>¿Cuál es la longitud del rectángulo?</p>
  <image source="svg-source/tikz-file-151228">
   <shortdescription>un rectángulo de 3 pulgadas y media de largo</shortdescription>
  </image>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <p><m>\frac{7}{2}</m> inches or <m>3\frac{1}{2}</m> inches</p>
  </solution>


