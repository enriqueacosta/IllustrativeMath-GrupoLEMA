<?xml version='1.0' encoding='utf-8'?>

<!-- ========================================================== 
  El cool-down es un <project> 
  (distinto a las otras actividades y a los Practice Problems)
===============================================================  -->
<project xml:id="cool-marcaLasPartes" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>Marca las partes</title>

<statement>
  <ol>
    <li>
      <sidebyside widths="50% 50%">
        <p>
          Marca cada parte con la fracción que le corresponde.
        </p>
        <image source="svg-source/tikz-file-151151">
          <shortdescription>rectángulo dividido en ocho partes iguales</shortdescription>
        </image>
      </sidebyside>
    </li>
    <li>
      <sidebyside widths="50% 50%">
        <p>
          Parte y colorea el rectángulo para mostrar <m>\frac{1}{4}</m>.
        </p>
        <image source="svg-source/tikz-file-151152">
          <shortdescription>rectángulo</shortdescription>
        </image>
      </sidebyside>
    </li>
  </ol>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <ol>
      <li>Student labels each part with <m>\frac{1}{8}</m>.</li>
      <li><p>Any drawing that shows 4 equal parts and 1 shaded part is acceptable. Sample responses:</p>
        <sidebyside widths="50% 50%">          
            <image source="svg-source/tikz-file-151153">
              <shortdescription>rectángulo dividido en cuatro partes iguales verticalmente, con una parte sombreada</shortdescription>
            </image>   
            <image source="svg-source/tikz-file-151154">
              <shortdescription>rectángulo dividido en cuatro partes iguales (dos filas con dos columnas), con una parte sombreada</shortdescription>
            </image>
        </sidebyside>
      </li>
    </ol>
  </solution>


<!-- ============================================================== 
