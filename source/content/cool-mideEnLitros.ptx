<?xml version='1.0' encoding='utf-8'?>

<!-- ========================================================== 
  El cool-down es un <project> 
  (distinto a las otras actividades y a los Practice Problems)
===============================================================  -->
<project xml:id="cool-mideEnLitros" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>Mide en litros</title>

<statement>
  <p>[@@@@@@@@@]</p>
</statement>

<solution>
  <p>[@@@@@@@@@]</p>
</solution>


<!-- ============================================================== 
   Notas profesor <prelude> (se pueden mostrar previo al enunciado)                      
===================================================================  -->
<prelude component="profesor">
  <!-- Estándares CCSS asociados -->
  <paragraphs>
    <title><custom ref="ccss-actividad-titulo"/></title> 
    <ul>
      <li> 
        <custom ref="ccss-addressing"/>
        <xref ref="ccss-3-MD-A-2" text="custom">3.MD.A.2</xref>,
        <xref ref="ccss-3-OA-C-7" text="custom">3.OA.C.7</xref>
      </li>
    </ul>
  </paragraphs>
</prelude>


<!-- ============================================================== 
   Notas profesor <postlude> (se pueden mostrar después del enunciado)                      
===================================================================  -->
<postlude component="profesor"> 

  <!-- Posibles errores -->
  <paragraphs>
    <title><custom ref="errores-cool-titulo"/></title>
    <p>[++++++++++++++++]</p>
    <p>[@@@@@@@@@]</p>
  </paragraphs>


  <!-- Estrategia de apoyo si muchos estudiantes respondieron incorrectamente -->
  <paragraphs>
    <title><custom ref="apoyo-cool-titulo"/></title>
    <p>[++++++++++++++++]</p>
    <p>[@@@@@@@@@]</p>
  </paragraphs>

</postlude>

</project>