<?xml version='1.0' encoding='utf-8'?>

<!-- ========================================================== 
  El cool-down es un <project> 
  (distinto a las otras actividades y a los Practice Problems)
===============================================================  -->
<project xml:id="cool-mideEnLitros" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>Mide en litros</title>

<statement>
  <p>¿Cuál es el volumen del líquido que se muestra en cada imagen?</p>  
  <sidebyside>
    <stack>
      <p>1</p>
      <image source="svg-source/qnnvh98hvnyxu5dcz4dhey0ftd66_c6Gh">
        <shortdescription>recipiente con 3 litros de líquido</shortdescription>
      </image>
      <p>
        <fillin characters="20" />
      </p>
    </stack>
    <stack>
      <p>
        2
      </p>    
      <image source="svg-source/a4yu17sbykhoyfzeq6q04tfnve7j_c6Gh">
        <shortdescription>recipiente con 1 litro y medio de líquido.</shortdescription>
      </image>
      <p>
        <fillin characters="20" />
      </p>
    </stack>
  </sidebyside>
</statement>

<solution>
  <p>[++++++++++++++++]</p>
  <ol>
    <li>
      <p>3 liters</p>
    </li>
    <li>
      <p>
        <m>1\frac{1}{2}</m> liters
      </p>
    </li>
  </ol>
</solution>


