<!-- ========================================================== 
  El cool-down es un <project> 
  (distinto a las otras actividades y a los Practice Problems)
===============================================================  -->
<project xml:id="cool-pajarosEnElParque" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>Pájaros en el parque</title>

<statement>
  <sidebyside>
 <stack>
    <p>Jada recolectó datos para saber cuántos pájaros de cada tipo vio camino a casa.</p>
    <p>Los datos se muestran en esta gráfica de dibujos:</p> 
    </stack>
    <image source="svg-source/tikz-file-174483">
        <shortdescription>Pictograma de pájaros con columnas de marcas de verificación</shortdescription>
      </image>
  </sidebyside>
 <p>
  A partir de los datos de la gráfica:
 </p>
 <ol>
  <li>
    <p>
   ¿Cuántos gorriones vio Jada camino a casa?   
    </p>
  </li>
  <li>
    <p>
   Escribe una pregunta que podrías hacer sobre los pájaros que Jada vio camino a casa.   
    </p>
  </li>
 </ol>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <ol>
      <li>10 sparrows</li>
      <li>Sample responses: How many birds did Jada see on the way home? How many blue jays and cardinals did Jada see on the way home?</li>
    </ol>
  </solution>


