<?xml version='1.0' encoding='utf-8'?>

<!-- ========================================================== 
  El cool-down es un <project> 
  (distinto a las otras actividades y a los Practice Problems)
===============================================================  -->
<project xml:id="cool-queTanLarga" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>¿Qué tan larga?</title>

<statement>
  <p>¿Cuál es la longitud de la lombriz, en pulgadas?</p>
  <image source="svg-source/V1-earthworm-3-75">
   <shortdescription>lombriz</shortdescription>
  </image>
  <image source="svg-source/tikz-file-159052">
   <shortdescription>regla con marcas de medias pulgadas y cuartos de pulgada</shortdescription>
  </image>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <p><m>3\frac{3}{4}</m> or <m>\frac{15}{4}</m> inches</p>
  </solution>


<!-- ============================================================== 
   Notas profesor <prelude> (se pueden mostrar previo al enunciado)                      
===================================================================  -->
<prelude component="profesor">
  <!-- Estándares CCSS asociados -->
  <paragraphs>
    <title><custom ref="ccss-actividad-titulo"/></title> 
    <ul>
      <li> 
        <custom ref="ccss-addressing"/>
        <xref ref="ccss-3-MD-B-4" text="custom">3.MD.B.4</xref>
      </li>
    </ul>
  </paragraphs>
</prelude>


<!-- ============================================================== 
   Notas profesor <postlude> (se pueden mostrar después del enunciado)                      
===================================================================  -->
<postlude component="profesor"> 

  <!-- Posibles errores -->
  <paragraphs>
    <title><custom ref="errores-cool-titulo"/></title><p>[++++++++++++++++]</p>
    <p>Students record a length of the worm that isn’t to the nearest quarter inch, such as <m>3\frac{1}{2}</m> inches or 4 inches.</p>
  </paragraphs>


  <!-- Estrategia de apoyo si muchos estudiantes respondieron incorrectamente -->
  <paragraphs>
    <title><custom ref="apoyo-cool-titulo"/></title><p>[++++++++++++++++]</p>
    <p>Before the next day’s warm-up, pass back the cool-down and have students discuss whether they would describe the length of the worm as <m>3\frac{3}{4}</m> inches or 4 inches and the reasoning behind their choice.</p>
  </paragraphs>

</postlude>

</project>