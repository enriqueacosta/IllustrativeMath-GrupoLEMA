<?xml version='1.0' encoding='utf-8'?>

<!-- ========================================================== 
  El cool-down es un <project> 
  (distinto a las otras actividades y a los Practice Problems)
===============================================================  -->
<project xml:id="cool-redondealoDosVeces" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>Redondéalo dos veces</title>

<statement>
  <ol>
    <li><p>Redondea 237 a la decena más cercana. Muestra o explica cómo razonaste.</p></li>
    <li><p>Redondea 237 a la centena más cercana. Muestra o explica cómo razonaste.</p></li>
  </ol>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <ol>
      <li>240. Sample response: 237 is between 230 and 240. It is closer to 240, since it’s only 3 away.</li>
      <li>200. Sample response: 237 is between 200 and 300. It is closer to 200, since it’s under 250.</li>
    </ol>
  </solution>


<!-- ============================================================== 
   Notas profesor <prelude> (se pueden mostrar previo al enunciado)                      
===================================================================  -->
<prelude component="profesor">
  <!-- Estándares CCSS asociados -->
  <paragraphs>
    <title><custom ref="ccss-actividad-titulo"/></title> 
    <ul>
      <li> 
        <custom ref="ccss-addressing"/>
        <xref ref="ccss-3-NBT-A-1" text="custom">3.NBT.A.1</xref>
      </li>
    </ul>
  </paragraphs>
</prelude>


<!-- ============================================================== 
   Notas profesor <postlude> (se pueden mostrar después del enunciado)                      
===================================================================  -->
<postlude component="profesor"> 

  <!-- Posibles errores -->
  <paragraphs>
    <title><custom ref="errores-cool-titulo"/></title>
    <p>[++++++++++++++++]</p>
    <p>Students round 237 to 230 or 300 when rounding to the nearest ten and hundred.</p>
  </paragraphs>


  <!-- Estrategia de apoyo si muchos estudiantes respondieron incorrectamente -->
  <paragraphs>
    <title><custom ref="apoyo-cool-titulo"/></title>
    <p>[++++++++++++++++]</p>
    <p>During the launch on the next day’s activity, display 237 on a number line marked with multiples of 10 and 100 and have students discuss the nearest multiple of 10 and 100.</p>
  </paragraphs>

</postlude>

</project>