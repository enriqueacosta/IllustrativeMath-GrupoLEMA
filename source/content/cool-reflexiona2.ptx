<?xml version='1.0' encoding='utf-8'?>

<!-- ========================================================== 
  El cool-down es un <project> 
  (distinto a las otras actividades y a los Practice Problems)
===============================================================  -->
<project xml:id="cool-reflexiona2" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>Reflexiona</title>

<statement>
  <p>Describe algo que entiendas muy bien después de la lección de hoy o describe algo que haya sido confuso o retador.</p>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <p>Sample responses:</p>
    <ul>
      <li>I understand that fractions show up on the number line in between whole numbers.</li>
      <li>I am confused about where to label fractions on the number line.</li>
    </ul>
  </solution>


<!-- ============================================================== 
   Notas profesor <prelude> (se pueden mostrar previo al enunciado)                      
===================================================================  -->
<prelude component="profesor">
  <!-- Estándares CCSS asociados -->
  <paragraphs>
    <title><custom ref="ccss-actividad-titulo"/></title> 
    <ul>
      <li> 
        <custom ref="ccss-addressing"/>
        <xref ref="ccss-3-NF-A-2" text="custom">3.NF.A.2</xref>
      </li>
    </ul>
  </paragraphs>
</prelude>


<!-- ============================================================== 
   Notas profesor <postlude> (se pueden mostrar después del enunciado)                      
===================================================================  -->
<postlude component="profesor"> 

  <!-- Posibles errores -->
  <paragraphs>
    <title><custom ref="errores-cool-titulo"/></title><p>[++++++++++++++++]</p>
    <p>Students have key ideas or lingering questions to discuss with other students.</p>
  </paragraphs>


  <!-- Estrategia de apoyo si muchos estudiantes respondieron incorrectamente -->
  <paragraphs>
    <title><custom ref="apoyo-cool-titulo"/></title><p>[++++++++++++++++]</p>
    <p>Before the next day's warm-up, pair students up to discuss their responses.</p>
  </paragraphs>

</postlude>

</project>