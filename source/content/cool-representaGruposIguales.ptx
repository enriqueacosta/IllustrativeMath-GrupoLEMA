<project xml:id="cool-representaGruposIguales" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>Representa grupos iguales</title>

<statement>
  <p>Jada tiene 3 bolsas. En cada bolsa hay 5 pulseras.</p>
  <p>Representa la situación.</p>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <p>Sample responses:</p>
    <sidebyside>
   <ul>
      <li>
        <p>Students make 3 groups of 5 counters or 3 groups of 5 connecting cubes.</p>
      </li>
      <li>
        <p>Students create a drawing of 3 groups with 5 items in each.</p>
      </li>
    </ul>
    <image source="svg-source/tikz-file-150942">
          <shortdescription>Tres grupos de cinco círculos azules dentro de óvalos.</shortdescription>
        </image>
    </sidebyside>
  </solution>


