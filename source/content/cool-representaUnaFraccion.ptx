  <!-- Posibles errores -->
  <paragraphs>
    <title><custom ref="errores-cool-titulo"/></title><p>[++++++++++++++++]</p>
    <p>Students partition the diagram into 8 parts and shade in 6 parts, but the parts aren't equal.</p>
