<project xml:id="cool-representaUnaFraccion" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>Representa una fracción</title>

<statement>
  <p>Esta tira representa 1 unidad. Parte el diagrama y coloréalo para representar <m>\frac{6}{8}</m>.</p>
  <image source="svg-source/tikz-file-151156">
    <shortdescription>rectángulo</shortdescription>
  </image>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <image source="svg-source/tikz-file-147454">
      <shortdescription>rectángulo dividido en 8 partes iguales con 6 partes sombreadas</shortdescription>
    </image>
  </solution>


