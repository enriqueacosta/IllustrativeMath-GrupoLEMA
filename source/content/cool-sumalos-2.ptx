<?xml version='1.0' encoding='utf-8'?>

<!-- ========================================================== 
  El cool-down es un <project> 
  (distinto a las otras actividades y a los Practice Problems)
===============================================================  -->
<project xml:id="cool-sumalos-2" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>Súmalos</title>

<statement>
  <p>Encuentra el valor de <m>258+217</m>. Explica o muestra tu razonamiento.</p>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <p>475. Sample response: I added the ones to get 15, the tens to get 60, and the hundreds to get 400. Then I added <m>15 + 60 + 400</m> to get 475.</p>
  </solution>


<!-- ============================================================== 
   Notas profesor <prelude> (se pueden mostrar previo al enunciado)                      
===================================================================  -->
