<?xml version='1.0' encoding='utf-8'?>

<!-- ========================================================== 
  El cool-down es un <project> 
  (distinto a las otras actividades y a los Practice Problems)
===============================================================  -->
<project xml:id="cool-tiemposAquellos" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>Tiempos aquellos</title>

<statement>
  <sidebyside widths="45% 45%" margins="0% 0%">
    <stack>
      <p>1.</p>
      <image source="svg-source/tikz-file-151235">
        <shortdescription>reloj marcando las 6:22</shortdescription>
      </image>
      <p>¿Qué hora se muestra? <fillin characters="15" /></p>
    </stack>
    <stack>
      <p>2.</p>
      <image source="svg-source/tikz-file-151236">
        <shortdescription>reloj en blanco</shortdescription>
      </image>
      <p>Muestra las 10:13 a.m. en el reloj.</p>
    </stack>
  </sidebyside>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <ol marker="1.">
      <li>
        <p>6:22</p>
      </li>
      <li>
        <image source="svg-source/tikz-file-134593">
          <shortdescription>reloj marcando las 10:13</shortdescription>
        </image>
      </li>
    </ol>
  </solution>


<!-- ============================================================== 
   Notas profesor <prelude> (se pueden mostrar previo al enunciado)                      
===================================================================  -->
<prelude component="profesor">
  <!-- Estándares CCSS asociados -->
  <paragraphs>
    <title><custom ref="ccss-actividad-titulo"/></title> 
    <ul>
      <li> 
        <custom ref="ccss-addressing"/>
        <xref ref="ccss-3-MD-A-1" text="custom">3.MD.A.1</xref>
      </li>
    </ul>
  </paragraphs>
</prelude>


<!-- ============================================================== 
   Notas profesor <postlude> (se pueden mostrar después del enunciado)                      
===================================================================  -->
<postlude component="profesor"> 

  <!-- Posibles errores -->
  <paragraphs>
    <title><custom ref="errores-cool-titulo"/></title>
    <p>[++++++++++++++++]</p>
    <p>Students do not tell or write time to the nearest minute, only the nearest 5 minutes.</p>
  </paragraphs>


  <!-- Estrategia de apoyo si muchos estudiantes respondieron incorrectamente -->
  <paragraphs>
    <title><custom ref="apoyo-cool-titulo"/></title>
    <p>[++++++++++++++++]</p>
    <p>Before the warm-up, invite students to work in small groups to discuss a correct response to this cool-down.</p>
  </paragraphs>

</postlude>

</project>