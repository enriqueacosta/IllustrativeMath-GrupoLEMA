<project xml:id="cool-ubicaMarcaYNombra" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>Ubica, marca y nombra</title>

<statement>
  <ol>
    <li><p>Ubica y marca 185 en la recta numérica a la que pertenece.</p>
      <image source="svg-source/tikz-file-147257">
        <shortdescription>recta numérica de 0 a 100 con 10 marcas.</shortdescription>
      </image>
      <image source="svg-source/tikz-file-147258">
        <shortdescription>recta numérica de 100 a 200 con 10 marcas.</shortdescription>
      </image>
      <image source="svg-source/tikz-file-147259">
          <shortdescription>recta numérica de 200 a 300 con 10 marcas.</shortdescription>
      </image>
    </li>
    <li><p>Escribe el múltiplo de 100 que está más cerca de 185.</p></li>
  </ol>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <ol>
      <li><p><line></line>
        <line><image source="svg-source/tikz-file-152774">
          <shortdescription>recta numérica de 100 a 200 con 10 marcas, con el 185 marcado.</shortdescription>
        </image></line>
      </p>        
      </li>
      <li>200</li>
    </ol>
  </solution>


