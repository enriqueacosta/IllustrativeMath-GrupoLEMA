  <!-- Propósito de la lección -->
  <paragraphs>
    <title><custom ref="purpose-leccion-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <p>The purpose of this lesson is for students to extend their understanding of whole numbers on the number line as they work with number lines partitioned into fractions.</p>
  </paragraphs>

  <!-- Materiales requeridos -->
  <paragraphs>
    <title><custom ref="materials-leccion-titulo"/></title>
    <p>[mmmmmmmmmm]</p>
    <!-- <ul>
      <li>
        <p>Actividad 1</p>
        <xi:include href="./act-clasificacionDeTarjetas-rectasNumericas-mat.ptx"/>
        <xi:include href="./act-clasificacionDeTarjetas-rectasNumericas-matCentros.ptx"/>
      </li>
