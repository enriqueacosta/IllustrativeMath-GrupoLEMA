  <!-- Propósito de la lección -->
  <paragraphs>
    <title><custom ref="purpose-leccion-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <p>The purpose of this lesson is for students to use their knowledge of base-ten diagrams to make sense of a written subtraction algorithm.</p>
  </paragraphs>

