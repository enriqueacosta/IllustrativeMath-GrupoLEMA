<shorttitle>Lección 17 </shorttitle>
<title>Lección 17 -<nbsp/></title>
<title>Comparemos fracciones</title>


<!-- ============================================ 
  Objetivos de aprendizaje                        
=================================================  -->

<!-- Frase resumen para estudiante. Originalmente [Student Facing Goals] -->
<introduction component="est-goal"> 
  <p>Comparemos más fracciones en diferentes situaciones.</p>
</introduction>

<!-- Objetivos para el estudiante. Originalmente [Student-Facing Targets] -->
<!-- <objectives component="estudiante">
  <ul>
    <li>[@@@@@@@@@@@@@@]</li>
  </ul>
</objectives> -->

<!-- Objetivos que solo ve el profesor. Originalmente [Teacher Facing Goals] -->
<objectives component="profesor">
  <ul>
    <li><p>[++++++++++++++++]</p></li>
    <li>
      <p>
        Compare two fractions with the same numerator or the same denominator.
      </p>
    </li>
    <li>
      <p>
        Record the results of comparison with the symbols <m>\gt</m>, <m>=</m>, or <m>\lt</m>.
      </p>
    </li>
  </ul>
</objectives>


