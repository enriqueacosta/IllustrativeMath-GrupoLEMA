  <!-- Propósito de la lección -->
  <paragraphs>
    <title><custom ref="purpose-leccion-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <p>The purpose of this lesson is for students to apply their understanding of length measurement, time measurement, and fluency with four operations to design a carnival game.</p>
  </paragraphs>

