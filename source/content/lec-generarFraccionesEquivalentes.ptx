<!-- Objetivos que solo ve el profesor. Originalmente [Teacher Facing Goals] -->
<objectives component="profesor">
  <ul>
    <li><p>[++++++++++++++++]</p></li>
    <li><p>Use diagrams to explain or show fraction equivalence.</p></li>
    <li><p>Use diagrams to generate equivalent fractions.</p></li>
  </ul>
</objectives>


