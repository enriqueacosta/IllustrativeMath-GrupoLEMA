  </ul>
</objectives> -->

<!-- Objetivos que solo ve el profesor. Originalmente [Teacher Facing Goals] -->
<objectives component="profesor">
  <ul>
    <li><p>[++++++++++++++++]</p></li>
    <li>
      <p>Interpret line plots that display measurement data in fractions of an inch.</p>
    </li>
  </ul>
</objectives>


