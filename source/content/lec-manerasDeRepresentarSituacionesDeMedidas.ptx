  <!-- Propósito de la lección -->
  <paragraphs>
    <title><custom ref="purpose-leccion-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <p>The purpose of this lesson is for students to make sense of situations involving measurements, interpret representations of the situations, and ask and answer questions about them.</p>
  </paragraphs>

  <!-- Materiales requeridos -->
  <paragraphs>
    <title><custom ref="materials-leccion-titulo"/></title>
    <p>[mmmmmmmmmm]</p>
