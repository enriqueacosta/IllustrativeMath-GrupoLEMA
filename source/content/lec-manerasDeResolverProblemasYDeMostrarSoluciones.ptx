  </paragraphs>

  <!-- Propósito de la lección -->
  <paragraphs>
    <title><custom ref="purpose-leccion-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <p>The purpose of this lesson is for students to solve problems using the four operations as they imagine spending a day at the fair.</p>
  </paragraphs>

  <!-- Materiales requeridos -->
  <paragraphs>
    <title><custom ref="materials-leccion-titulo"/></title>
    <p>[mmmmmmmmmm]</p>
    <!-- <ul>
      <li>
        <p>Actividad 1</p>
        <xi:include href="./act-unDiaEnLaFeria-mat.ptx"/>
