  <!-- Propósito de la lección -->
  <paragraphs>
    <title><custom ref="purpose-leccion-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <p>The purpose of this lesson is for students to partition shapes into equal parts and express each equal-size part as a unit fraction.</p>
  </paragraphs>

  <!-- Materiales requeridos -->
  <paragraphs>
    <title><custom ref="materials-leccion-titulo"/></title>
    <p>[mmmmmmmmmm]</p>
    <!-- <ul>
      <li>
