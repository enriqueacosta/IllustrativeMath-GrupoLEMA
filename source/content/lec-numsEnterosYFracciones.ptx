  <!-- Propósito de la lección -->
  <paragraphs>
    <title><custom ref="purpose-leccion-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <p>The purpose of this lesson is for students to recognize fractions that are equivalent to whole numbers and write whole numbers as fractions.</p>
  </paragraphs>

  <!-- Materiales requeridos -->
  <paragraphs>
    <title><custom ref="materials-leccion-titulo"/></title>
    <p>[mmmmmmmmmm]</p>
