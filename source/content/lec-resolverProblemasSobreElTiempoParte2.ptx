  <!-- Propósito de la lección -->
  <paragraphs>
    <title><custom ref="purpose-leccion-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <p>The purpose of this lesson is for students to solve problems involving addition and subtraction of time intervals in minutes.</p>
  </paragraphs>

  <!-- Materiales requeridos -->
  <paragraphs>
    <title><custom ref="materials-leccion-titulo"/></title>
    <p>[mmmmmmmmmm]</p>
