  <!-- Propósito de la lección -->
  <paragraphs>
    <title><custom ref="purpose-leccion-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <p>The purpose of this lesson is for students to record newly composed tens and hundreds with a single digit and to consider when they might use algorithms or other strategies to add.</p>
  </paragraphs>

  <!-- Materiales requeridos -->
  <paragraphs>
    <title><custom ref="materials-leccion-titulo"/></title>
    <p>[mmmmmmmmmm]</p>
    <!-- <ul>
      <li>
        <p>Actividad 1</p>
        <xi:include href="./act-soloUnidades-mat.ptx"/>
        <xi:include href="./act-soloUnidades-matCentros.ptx"/>
      </li>
