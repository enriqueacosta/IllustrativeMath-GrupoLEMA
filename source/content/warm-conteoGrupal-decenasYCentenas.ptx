  <!-- Tiempo recomendado -->
  <paragraphs>
    <title><custom ref="recommended-time-titulo"/></title>
    <p>10 minutos</p>
  </paragraphs>

  <!-- Introducción de la actividad -->  
  <paragraphs>
    <title><custom ref="narrative-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <p>The purpose of this Choral Count is for students to practice counting by 10 and 100 and notice patterns in the count. These understandings help students develop fluency and will help students see that multiples of 100 are also multiples of 10, and prepare them to round large numbers to the nearest ten and hundred.</p>
  </paragraphs>

  <!-- Materiales requeridos de la actividad -->
  <paragraphs>
    <title><custom ref="materials-actividad-titulo"/></title>
    <p>[mmmmmmmmmm]</p>
    <!-- <xi:include href="./warm-conteoGrupal-decenasYCentenas-mat.ptx"/>  -->
  </paragraphs>

  <!-- Launch -->
  <paragraphs>
    <title><custom ref="launch-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>
        <q>Contemos de 10 en 10, empezando en 0</q>
      </li>
      <li>Record as students count.</li>
      <li>Stop counting and recording at 200.</li>
      <li>
        <q>Contemos de 100 en 100, empezando en 0</q>
      </li>
      <li>Record as students count.</li>
      <li>Stop counting and recording at 900.</li>
    </ul>
  </paragraphs>

  <!-- Instrucciones para el desarrollo de la actividad -->
  <paragraphs>
    <title><custom ref="instructions-teacher-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>
        <q>¿Qué patrones ven?</q>
      </li>
      <li>1–2 minutes: quiet think time</li>
      <li>Record responses.</li>
    </ul>
  </paragraphs>

</prelude>


