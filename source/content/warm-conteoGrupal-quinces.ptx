<?xml version='1.0' encoding='utf-8'?>

<!-- ====================================================================== 
   El calentamiento es un <exploration> (distinto a las otras actividades)
   Para RRRRR usar el estilo del calentamiento. Por ejemplo, usar 
   RRRRRR=observa con los "Observa y Pregúntate"
===========================================================================  -->
<exploration xml:id="warm-conteoGrupal-quinces" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>Conteo grupal: Quinces</title>

<statement>
  <p>Contemos de 15 minutos en 15 minutos, empezando en las 12:00.</p>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <p>Sample responses:</p>
    <ul>
      <li>Every 4 counts you get to a new hour.</li>
      <li>Three hours pass during the count because you go from 12:00 to 3:00.</li>
      <li>The minutes have a pattern of 00, 15, 30, 45, then back to 00, which is the next hour.</li>
    </ul>
  </solution>


<!-- ============================================================== 
   Notas profesor <prelude> (se pueden mostrar previo al enunciado)                      
===================================================================  -->
<prelude component="profesor"> 

  <!-- Estándares CCSS asociados -->
  <paragraphs>
    <title><custom ref="ccss-actividad-titulo"/></title> 
    <ul>
      <li> 
        <custom ref="ccss-addressing"/>
        <xref ref="ccss-3-MD-A-1" text="custom">3.MD.A.1</xref>
      </li>
    </ul>
  </paragraphs>

  <!-- Tiempo recomendado -->
  <paragraphs>
    <title><custom ref="recommended-time-titulo"/></title>
    <p>10 minutos</p>
  </paragraphs>

  <!-- Introducción de la actividad -->  
  <paragraphs>
    <title><custom ref="narrative-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <p>The purpose of this Choral Count is to invite students to practice counting times by 15 minutes and notice patterns in the count. This will be helpful later in this section when students will solve problems involving addition and subtraction of time intervals.</p>
    <p>Students have an opportunity to notice regularity through repeated reasoning (MP8) as they count by 15 minutes over a span of 3 hours.</p>
  </paragraphs>

  <!-- Launch -->
  <paragraphs>
    <title><custom ref="launch-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>
        <q>Contemos de 15 minutos en 15 minutos, empezando en las 12:00</q>
      </li>
      <li>Record as students count. Record times in the count in a single column.</li>
      <li>Stop counting and recording at 3:00.</li>
    </ul>
  </paragraphs>

  <!-- Instrucciones para el desarrollo de la actividad -->
  <paragraphs>
    <title><custom ref="instructions-teacher-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>
        <q>¿Qué patrones ven?</q>
      </li>
      <li>1–2 minutes: quiet think time</li>
      <li>Record responses.</li>
    </ul>
  </paragraphs>

</prelude>


<!-- ============================================================== 
   Notas profesor <postlude> (se pueden mostrar después del enunciado)                      
===================================================================  -->
<postlude component="profesor">

  <!-- Síntesis de la actividad -->
  <paragraphs>
    <title><custom ref="synthesis-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>
        <q>¿Cuánto tiempo transcurrió entre la 1:15 y la 1:45?</q>  (30 minutes) 
        <q>¿Entre la 1:15 y las 2:30?</q>  (75 minutes)
      </li>
      <li><p>Consider asking:</p>
        <ul>
          <li><q>¿Quién puede describir el patrón con otras palabras?</q></li>
          <li><q>¿Alguien quiere compartir otra observación sobre por qué ocurre ese patrón aquí?</q></li>
          <li><q>¿Están de acuerdo o en desacuerdo? ¿Por qué?</q></li>
        </ul>
      </li>
    </ul>
  </paragraphs>

</postlude>

</exploration>