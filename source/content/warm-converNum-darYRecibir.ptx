<!-- ====================================================================== 
   El calentamiento es un <exploration> (distinto a las otras actividades)
   Para RRRRR usar el estilo del calentamiento. Por ejemplo, usar 
   RRRRRR=observa con los "Observa y Pregúntate"
===========================================================================  -->
<exploration xml:id="warm-converNum-darYRecibir" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>[@@@@@@@@@]</title>

<statement>
  <p>[@@@@@@@@@]</p>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <p>Sample responses:</p>
<ul>
      <li>505: I took 1 away from 506 and added it to 199 to make 200. <m>305 + 200 = 505</m></li>
      <li>615: I took 3 from 318 to make 315 and added the 3 to 297 to make 300. <m>315 + 300 = 615</m></li>
      <li>600: 200 plus 300 is 500 and 75 plus 25 is another 100.</li>
      <li>604: It’s 4 more than the previous expression.</li>
    </ul>
  </solution>


