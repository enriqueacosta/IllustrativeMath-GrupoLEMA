<?xml version='1.0' encoding='utf-8'?>

<!-- ====================================================================== 
   El calentamiento es un <exploration> (distinto a las otras actividades)
   Para RRRRR usar el estilo del calentamiento. Por ejemplo, usar 
   RRRRRR=observa con los "Observa y Pregúntate"
===========================================================================  -->
<exploration xml:id="warm-converNum-dividamosEntre3" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>Conversación numérica: Dividamos entre 3</title>

<statement>
  <p>Encuentra mentalmente el valor de cada expresión.</p>
  <ul>
    <li>
      <p><m>30\div 3</m></p>
    </li>
    <li><p><m>60\div 3</m></p></li>
    <li><p><m>63\div 3</m></p></li>
    <li><p><m>54\div 3</m></p></li>
  </ul>
</statement>

<solution>
  <ul>
    <li>
      <p>10</p>
    </li>
    <li>
      <p>20</p>
    </li>
    <li>
      <p>21</p>
    </li>
    <li>
      <p>18</p>
    </li>
  </ul>
</solution>


<!-- ============================================================== 
   Notas profesor <prelude> (se pueden mostrar previo al enunciado)                      
===================================================================  -->
<prelude component="profesor"> 

  <!-- Estándares CCSS asociados -->
  <paragraphs>
    <title><custom ref="ccss-actividad-titulo"/></title> 
    <ul>
      <li> 
        <custom ref="ccss-addressing"/>
        <xref ref="ccss-3-OA-C-7" text="custom">3.OA.C.7</xref>
      </li>
    </ul>
  </paragraphs>

  <!-- Tiempo recomendado -->
  <paragraphs>
    <title><custom ref="recommended-time-titulo"/></title>
    <p>10 minutos</p>
  </paragraphs>

  <!-- Introducción de la actividad -->  
  <paragraphs>
    <title><custom ref="narrative-actividad-titulo"/></title>
    <p>[++++++++++++++++]</p>
    <p>The purpose of this Number Talk is to elicit strategies and understandings students have for dividing within 100 and to help students develop fluency.</p>
    <p>When students use known multiplication and division facts to divide larger numbers, they look for and make use of structure (MP7).</p>
  </paragraphs>

  <!-- Launch -->
  <paragraphs>
    <title><custom ref="launch-titulo"/></title>
    <p>[++++++++++++++++]</p>
    <ul>
      <li>
        <p>Display one expression.</p>
      </li>
      <li><p><q>Hagan una señal cuando tengan una respuesta y puedan explicar cómo la obtuvieron</q></p></li>
      <li><p>1 minute: quiet think time</p></li>
    </ul>
  </paragraphs>

  <!-- Instrucciones para el desarrollo de la actividad -->
  <paragraphs>
    <title><custom ref="instructions-teacher-actividad-titulo"/></title>
    <p>[++++++++++++++++]</p>
    <ul>
      <li>
        <p>Record answers and strategy.</p>
      </li>
      <li><p>Keep expressions and work displayed.</p></li>
      <li><p>Repeat with each expression.</p></li>
    </ul>
  </paragraphs>

</prelude>


<!-- ============================================================== 
   Notas profesor <postlude> (se pueden mostrar después del enunciado)                      
===================================================================  -->
<postlude component="profesor">

  <!-- Síntesis de la actividad -->
  <paragraphs>
    <title><custom ref="synthesis-actividad-titulo"/></title>
    <p>[++++++++++++++++]</p>
    <p><q>¿Cómo usaron los hechos de división que ya conocen para encontrar algunos de los otros cocientes?</q> (I knew that <m>60\div 3</m> would be double the answer of <m>30\div 3</m>. Once I knew <m>60\div 3</m>, I was able to find <m>63\div 3</m> by adding another group of 3 and <m>54\div 3</m> by taking groups of 3 away.)</p>
  </paragraphs>

</postlude>

</exploration>