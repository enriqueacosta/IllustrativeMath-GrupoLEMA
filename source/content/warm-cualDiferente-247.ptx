<?xml version='1.0' encoding='utf-8'?>

<!-- ====================================================================== 
   El calentamiento es un <exploration> (distinto a las otras actividades)
   Para RRRRR usar el estilo del calentamiento. Por ejemplo, usar 
   RRRRRR=observa con los "Observa y Pregúntate"
===========================================================================  -->
<exploration xml:id="warm-cualDiferente-247" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>Cuál es diferente: 247</title>

<statement>
  <p>¿Cuál es diferente?</p>
  <sbsgroup widths="50% 50%">
    <sidebyside>
      <p>A. <m>200+30+17</m></p>
      <p>B. <m>247</m></p>
    </sidebyside>
    <sidebyside>
      <p>C. <m>200+47+10</m></p>
      <p>D. <m>100+140+7</m></p>
    </sidebyside>
  </sbsgroup>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>A is the only one that doesn’t have a 4 in it.</li>
      <li>B is the only one that doesn’t have any plus signs and is not a sum of hundreds, tens, and ones.</li>
      <li>C is the only one that is not equal to 247.</li>
      <li>D is the only one that doesn’t have a 2 in it.</li>
    </ul>
  </solution>


<!-- ============================================================== 
   Notas profesor <prelude> (se pueden mostrar previo al enunciado)                      
===================================================================  -->
<prelude component="profesor"> 

  <!-- Estándares CCSS asociados -->
  <paragraphs>
    <title><custom ref="ccss-actividad-titulo"/></title> 
    <ul>
      <li> 
        <custom ref="ccss-addressing"/>
        <xref ref="ccss-3-NBT-A-2" text="custom">3.NBT.A.2</xref>
      </li>
    </ul>
  </paragraphs>

  <!-- Tiempo recomendado -->
  <paragraphs>
    <title><custom ref="recommended-time-titulo"/></title>
    <p>10 minutos</p>
  </paragraphs>

  <!-- Introducción de la actividad -->  
  <paragraphs>
    <title><custom ref="narrative-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <p>This warm-up prompts students to compare three expressions and one three-digit number. During the synthesis, ask students to explain the meaning of any terminology they use, such as the value of each expression and ways that place value was used to write the number 247 in different ways.</p>
  </paragraphs>

  <!-- Launch -->
  <paragraphs>
    <title><custom ref="launch-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>Groups of 2</li>
      <li>Display the expressions and number.</li>
      <li>
        <q>Escojan una que sea diferente. Prepárense para compartir por qué es diferente</q>
      </li>
      <li>1 minute: quiet think time</li>
    </ul>
  </paragraphs>

  <!-- Instrucciones para el desarrollo de la actividad -->
  <paragraphs>
    <title><custom ref="instructions-teacher-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>
        <q>Discutan con su compañero lo que pensaron</q>
      </li>
      <li>2-3 minutes: partner discussion</li>
      <li>Share and record responses.</li>
    </ul>
  </paragraphs>

</prelude>


<!-- ============================================================== 
   Notas profesor <postlude> (se pueden mostrar después del enunciado)                      
===================================================================  -->
<postlude component="profesor">

  <!-- Síntesis de la actividad -->
  <paragraphs>
    <title><custom ref="synthesis-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>
        <q>¿Cómo supieron que A y D eran iguales a 247?</q>  (In A there were 2 hundreds, 4 tens, and 7 ones, but some of the tens were with the ones. In D there were 2 hundreds, 4 tens, and 7 ones, but some of the hundreds were with the tens.)
      </li>
      <li>Consider stating: 
        <q>Encontremos por lo menos una razón por la que cada una es diferente</q>
      </li>
    </ul>
  </paragraphs>

</postlude>

</exploration>