<!-- ====================================================================== 
   El calentamiento es un <exploration> (distinto a las otras actividades)
   Para RRRRR usar el estilo del calentamiento. Por ejemplo, usar 
   RRRRRR=observa con los "Observa y Pregúntate"
===========================================================================  -->
<exploration xml:id="warm-cualDiferente-figurasConPartes" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>[@@@@@@@@@]</title>

<statement>
  <p>[@@@@@@@@@]</p>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <p>Sample responses:</p>
<ul>
      <li>A is the only one that hasn’t been split vertically, it’s split diagonally.</li>
      <li>B is the only one that is not unshaded.</li>
      <li>C is the only one that isn’t a square and doesn’t have corners.</li>
      <li>D is the only one that has pieces or parts that aren’t the same size.</li>
    </ul>
  </solution>


<!-- ============================================================== 
   Notas profesor <prelude> (se pueden mostrar previo al enunciado)                      
===================================================================  -->
<prelude component="profesor"> 

  <!-- Estándares CCSS asociados -->
  <paragraphs>
    <title><custom ref="ccss-actividad-titulo"/></title> 
    <ul>
      <li> 
        <custom ref="ccss-addressing"/>
        [@@@@@@@@@]
        <!-- <xref ref="ccss-2-MD" text="custom">2.MD</xref>,  -->
        <!-- <xref ref="ccss-2-OA-C-4" text="custom">2.OA.C.4</xref> -->
      </li>
      <li>
        <custom ref="ccss-buildingOn"/>
        [@@@@@@@@@]
        <!-- <xref ref="ccss-2-MD" text="custom">2.MD</xref>,  -->
        <!-- <xref ref="ccss-2-OA-C-4" text="custom">2.OA.C.4</xref> -->
      </li>
      <li>
        <custom ref="ccss-buildingTowards"/>
        [@@@@@@@@@]
        <!-- <xref ref="ccss-2-MD" text="custom">2.MD</xref>,  -->
        <!-- <xref ref="ccss-2-OA-C-4" text="custom">2.OA.C.4</xref> -->
      </li>
    </ul>
  </paragraphs>

  <!-- Tiempo recomendado -->
  <paragraphs>
    <title><custom ref="recommended-time-titulo"/></title>
    <p>10 minutos</p>
  </paragraphs>

  <!-- Introducción de la actividad -->  
  <paragraphs>
    <title><custom ref="narrative-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <p>This warm-up prompts students to compare four shapes that have been partitioned and examine the features of the shapes and the partitions. The observations here prepare students to explore fractions later in the lesson and enable the teacher to hear how students describe the features that they see. During the synthesis, ask students to explain the meaning of any terminology they use, such as partition, whole, parts, pieces, equal, and halves.</p>
  </paragraphs>

  <!-- Materiales requeridos de la actividad -->
  <paragraphs>
    <title><custom ref="materials-actividad-titulo"/></title>
    <p>[mmmmmmmmmm]</p>
    <!-- <xi:include href="./warm-cualDiferente-figurasConPartes-mat.ptx"/>  -->
  </paragraphs>

  <!-- Launch -->
  <paragraphs>
    <title><custom ref="launch-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>Groups of 2</li>
      <li>Display the image.</li>
      <li>
        <q>Escojan una que sea diferente. Prepárense para compartir por qué es diferente</q>
      </li>
      <li>1 minute: quiet think time</li>
    </ul>
  </paragraphs>

  <!-- Instrucciones para el desarrollo de la actividad -->
  <paragraphs>
    <title><custom ref="instructions-teacher-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>
        <q>Discutan con su pareja lo que pensaron</q>
      </li>
      <li>2–3 minutes: partner discussion</li>
      <li>Share and record responses.</li>
    </ul>
  </paragraphs>

</prelude>


<!-- ============================================================== 
   Notas profesor <postlude> (se pueden mostrar después del enunciado)                      
===================================================================  -->
<postlude component="profesor">

  <!-- Estrategias de apoyo para estudiantes con dificultades -->
  <paragraphs>
    <title><custom ref="support-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <p>=== NOT PRESENT ===</p>
  </paragraphs>

  <!-- Síntesis de la actividad -->
  <paragraphs>
    <title><custom ref="synthesis-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>
        <q>¿Por qué no podemos decir que D está dividida en medios?</q>  (The pieces or parts aren’t the same size. The pieces have to be equal.)
      </li>
      <li>
        <q>Otra palabra que podemos usar para decir que algo está dividido en pedazos o partes es partición. Hacer una partición significa dividir en partes</q>
      </li>
    </ul>
  </paragraphs>


  <!-- Descripción del desarrollo de lenguaje matemático -->
  <paragraphs>
    <title><custom ref="language-actividad-titulo"/></title>
    <p>[@@@@@@@@@]</p>
  </paragraphs>

  <!-- Estrategias de acceso para estudiantes con discapacidades -->
  <paragraphs>
    <title><custom ref="accesibility-actividad-titulo"/></title>
    <p>[@@@@@@@@@]</p>
  </paragraphs>

</postlude>

</exploration>