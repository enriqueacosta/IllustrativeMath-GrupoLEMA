<?xml version='1.0' encoding='utf-8'?>

<!-- ====================================================================== 
   El calentamiento es un <exploration> (distinto a las otras actividades)
   Para RRRRR usar el estilo del calentamiento. Por ejemplo, usar 
   RRRRRR=observa con los "Observa y Pregúntate"
===========================================================================  -->
<exploration xml:id="warm-cuantosVes-masGruposDePuntos" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>Cuántos ves: Más grupos de puntos</title>

<statement>
  <p>¿Cuántos ves? ¿Cómo lo sabes?, ¿qué ves?</p>
  <image source="svg-source/tikz-file-148063">
        <shortdescription>Tres grupos de cinco círculos azules</shortdescription>
      </image>
      <image source="svg-source/tikz-file-147445">
        <shortdescription>Cinco grupos de cinco círculos azules</shortdescription>
      </image>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>15: I saw 3 groups of 5.</li>
      <li>25: I saw 5 groups of 5.</li>
    </ul>
  </solution>


<!-- ============================================================== 
   Notas profesor <prelude> (se pueden mostrar previo al enunciado)                      
===================================================================  -->
<prelude component="profesor"> 

  <!-- Estándares CCSS asociados -->
  <paragraphs>
    <title><custom ref="ccss-actividad-titulo"/></title> 
    <ul>
      <li> 
        <custom ref="ccss-addressing"/>
        <xref ref="ccss-3-MD-B-3" text="custom">3.MD.B.3</xref>
      </li>
    </ul>
  </paragraphs>

  <!-- Tiempo recomendado -->
  <paragraphs>
    <title><custom ref="recommended-time-titulo"/></title>
    <p>10 minutos</p>
  </paragraphs>

  <!-- Introducción de la actividad -->  
  <paragraphs>
    <title><custom ref="narrative-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <p>The purpose of this activity is for students to subitize or use grouping strategies to describe the number of dots they see. Although the dots have been deliberately grouped by 5 to elicit counting by 5 as a strategy, students may see 2 groups of 5 as 10. Grouping strategies and skip-counting by 2, 5, and 10 offer a review of grade 2 work and build toward multiplication in future lessons. </p>
  </paragraphs>

  <!-- Launch -->
  <paragraphs>
    <title><custom ref="launch-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>Groups of 2</li>
      <li>
        <q>¿Cuántos ven? ¿Cómo lo saben?, ¿qué ven?</q>
      </li>
      <li>Flash the image.</li>
      <li>30 seconds: quiet think time</li>
    </ul>
  </paragraphs>

  <!-- Instrucciones para el desarrollo de la actividad -->
  <paragraphs>
    <title><custom ref="instructions-teacher-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>Display the image. </li>
      <li>
        <q>Discutan con su pareja cómo pensaron</q>
      </li>
      <li>1 minute: partner discussion</li>
      <li>Record responses.</li>
      <li>Repeat for each image.</li>
    </ul>
  </paragraphs>

</prelude>


<!-- ============================================================== 
   Notas profesor <postlude> (se pueden mostrar después del enunciado)                      
===================================================================  -->
<postlude component="profesor">

  <!-- Síntesis de la actividad -->
  <paragraphs>
    <title><custom ref="synthesis-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>
        <q>¿Qué patrón vieron primero y cómo les ayudó a averiguar el total?</q>  (I saw that the dots were in groups of 5. This helped me because I know how to count by 5.)
      </li>
      <li><p>Consider asking:</p><ul>
        <li>
          <q>¿Alguien vio los puntos de la misma manera, pero lo explicaría de otra forma?</q></li>
        <li>
          <q>¿Alguien quiere compartir otra observación sobre la manera en que <fillin/> vio los puntos?</q></li>
        </ul>
      </li>
    </ul>
  </paragraphs>

</postlude>

</exploration>