<?xml version='1.0' encoding='utf-8'?>

<!-- ====================================================================== 
   El calentamiento es un <exploration> (distinto a las otras actividades)
   Para RRRRR usar el estilo del calentamiento. Por ejemplo, usar 
   RRRRRR=observa con los "Observa y Pregúntate"
===========================================================================  -->
<exploration xml:id="warm-cuantosVes-puntosEnGrupos" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>Cuántos ves: Puntos en grupos</title>

<statement>
  <p>¿Cuántos ves? ¿Cómo lo sabes?, ¿qué ves?</p>
  <image source="svg-source/tikz-file-148053">
        <shortdescription>Grupo de puntos, dos filas de 3 puntos cada una.</shortdescription>
  </image>
  <image source="svg-source/tikz-file-148054">
        <shortdescription>Dos grupos de puntos, dos filas de 2 puntos en cada grupo.</shortdescription>
  </image>
  <image source="svg-source/tikz-file-148055">
        <shortdescription>Cinco grupos con 2 puntos en cada uno.</shortdescription>
  </image>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>6: I see 2 rows of 3</li>
      <li>8: I see 2 groups of 4</li>
      <li>10: I see 5 groups of 2</li>
    </ul>
  </solution>


<!-- ============================================================== 
   Notas profesor <prelude> (se pueden mostrar previo al enunciado)                      
===================================================================  -->
<prelude component="profesor"> 

  <!-- Estándares CCSS asociados -->
  <paragraphs>
    <title><custom ref="ccss-actividad-titulo"/></title> 
    <ul>
      <li>
        <custom ref="ccss-buildingOn"/>
        <xref ref="ccss-2-OA-C-3" text="custom">2.OA.C.3</xref>
      </li>
    </ul>
  </paragraphs>

  <!-- Tiempo recomendado -->
  <paragraphs>
    <title><custom ref="recommended-time-titulo"/></title>
    <p>10 minutos</p>
  </paragraphs>

  <!-- Introducción de la actividad -->  
  <paragraphs>
    <title><custom ref="narrative-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <p>The purpose of this How Many Do You See is for students to subitize or use grouping strategies to describe the number of dots they see. They also make connections between the images to determine the number of dots. Grouping strategies and skip-counting by 2, 5, and 10 offer a review of grade 2 work and build toward multiplication in future lessons. In the synthesis, students revisit the language of <q>how many more</q> to prepare them to use data from a bar graph to solve <q>how many more</q> problems throughout this lesson.</p>
  </paragraphs>

  <!-- Launch -->
  <paragraphs>
    <title><custom ref="launch-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>Groups of 2</li>
      <li>
        <q>¿Cuántos ven? ¿Cómo lo saben?, ¿qué ven?</q>
      </li>
      <li>Flash the image.</li>
      <li>30 seconds: quiet think time</li>
    </ul>
  </paragraphs>

  <!-- Instrucciones para el desarrollo de la actividad -->
  <paragraphs>
    <title><custom ref="instructions-teacher-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>Display the image. </li>
      <li>
        <q>Discutan con su pareja lo que pensaron</q>
      </li>
      <li>1 minute: partner discussion</li>
      <li>Record responses.</li>
      <li>Repeat for each image.</li>
    </ul>
  </paragraphs>

</prelude>


<!-- ============================================================== 
   Notas profesor <postlude> (se pueden mostrar después del enunciado)                      
===================================================================  -->
<postlude component="profesor">

  <!-- Estrategias de apoyo para estudiantes con dificultades -->
  
  <!-- Síntesis de la actividad -->
  <paragraphs>
    <title><custom ref="synthesis-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>
        <q>¿Cuántos puntos más había en la tercera imagen que en la segunda imagen? ¿Qué ecuación corresponde a lo que pensaron?</q>  (There were 2 more dots in the image. <m>8 + 2 = 10</m>.)
      </li>
    </ul>
  </paragraphs>

</postlude>

</exploration>