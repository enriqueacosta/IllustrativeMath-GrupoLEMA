<?xml version='1.0' encoding='utf-8'?>

<!-- ====================================================================== 
   El calentamiento es un <exploration> (distinto a las otras actividades)
   Para RRRRR usar el estilo del calentamiento. Por ejemplo, usar 
   RRRRRR=observa con los "Observa y Pregúntate"
===========================================================================  -->
<exploration xml:id="warm-exploracionDeEstimacion-laLongitudDeUnaMariquita" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>Exploración de estimación: La longitud de una mariquita</title>

<statement>
  <p>¿Cuál es la longitud de esta mariquita?</p>
  <image source="png-source/3.5.D17 Warmup_ES.png" width="70%">
    <shortdescription>foto de una mariquita sobre una rama que mide 1 pulgada</shortdescription>
  </image>
  <p>
    Escribe una estimación que sea:
  </p>
  <tabular top="medium">
    <row header="yes" left="medium" bottom="medium" halign="center" valign="middle">
      <cell right="medium">muy baja</cell>
      <cell right="medium">razonable</cell>
      <cell right="medium">muy alta</cell>
    </row>
    <row left="minor" bottom="minor">
      <cell right="minor"><nbsp/></cell>
      <cell right="minor"><nbsp/></cell>
      <cell right="minor"><nbsp/></cell>    </row>    
  </tabular>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <p>Sample responses:</p>
    <ul>
      <li>Too low: <m>\frac{1}{4}</m> or less</li>
      <li>About right: between <m>\frac{1}{4}</m> and <m>\frac{1}{2}</m> inch</li>
      <li>Too high: <m>\frac{3}{4}</m> inch or greater</li>
    </ul>
  </solution>


<!-- ============================================================== 
   Notas profesor <prelude> (se pueden mostrar previo al enunciado)                      
===================================================================  -->
<prelude component="profesor"> 

  <!-- Estándares CCSS asociados -->
  <paragraphs>
    <title><custom ref="ccss-actividad-titulo"/></title> 
    <ul>
      <li>
        <custom ref="ccss-buildingTowards"/>
        <xref ref="ccss-3-MD-B-4" text="custom">3.MD.B.4</xref>
      </li>
    </ul>
  </paragraphs>

  <!-- Tiempo recomendado -->
  <paragraphs>
    <title><custom ref="recommended-time-titulo"/></title>
    <p>10 minutos</p>
  </paragraphs>

  <!-- Introducción de la actividad -->  
  <paragraphs>
    <title><custom ref="narrative-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <p>The purpose of an Estimation Exploration is to practice the skill of estimating a reasonable answer based on experience and known information. In this warm-up, students apply what they know about fractions to estimate the length of an insect that is less than 1 inch.</p>
  </paragraphs>

  <!-- Launch -->
  <paragraphs>
    <title><custom ref="launch-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>Groups of 2</li>
      <li>Display the image.</li>
      <li>
        <q>¿Qué estimación sería muy alta?, ¿muy baja?, ¿razonable?</q>
      </li>
      <li>1 minute: quiet think time</li>
    </ul>
  </paragraphs>

  <!-- Instrucciones para el desarrollo de la actividad -->
  <paragraphs>
    <title><custom ref="instructions-teacher-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>
        <q>Discutan con su compañero cómo pensaron</q>
      </li>
      <li>1 minute: partner discussion</li>
      <li>Record responses.</li>
    </ul>
  </paragraphs>

</prelude>


<!-- ============================================================== 
   Notas profesor <postlude> (se pueden mostrar después del enunciado)                      
===================================================================  -->
<postlude component="profesor">

  <!-- Síntesis de la actividad -->
  <paragraphs>
    <title><custom ref="synthesis-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li><p>Consider asking:</p>
        <ul>
          <li><q>¿La estimación de alguno es menor que <fillin/>? ¿La estimación de alguno es mayor que <fillin/>?</q></li>
          <li><q>Teniendo en cuenta esta discusión, ¿alguien quiere ajustar su estimación?</q></li>
        </ul>
      </li>
    </ul>
  </paragraphs>

</postlude>

</exploration>