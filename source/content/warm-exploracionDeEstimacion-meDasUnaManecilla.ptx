<?xml version='1.0' encoding='utf-8'?>

<!-- ====================================================================== 
   El calentamiento es un <exploration> (distinto a las otras actividades)
   Para RRRRR usar el estilo del calentamiento. Por ejemplo, usar 
   RRRRRR=observa con los "Observa y Pregúntate"
===========================================================================  -->
<exploration xml:id="warm-exploracionDeEstimacion-meDasUnaManecilla" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>Exploración de estimación: ¿Me das una manecilla?</title>

<statement>
  <sidebyside widths="70% 30%">
    <stack>
      <p>Este reloj solo tiene la manecilla de las horas.</p>
      <p>¿Qué hora puede ser?</p>
    </stack>
    <image source="svg-source/tikz-file-152786">
        <shortdescription>reloj marcando la 1</shortdescription>
      </image>
  </sidebyside>
  <p>Escribe una estimación que sea:</p>
  <tabular top="medium" halign="center" valign="middle">
    <row header="yes" left="medium" bottom="medium">
      <cell right="medium">muy temprano</cell>
      <cell right="medium">razonable</cell>
      <cell right="medium">muy tarde</cell>
    </row>
    <row left="minor" bottom="minor">
      <cell right="minor"><nbsp/></cell>
      <cell right="minor"><nbsp/></cell>
      <cell right="minor"><nbsp/></cell>    </row>    
  </tabular>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <p>Sample responses:</p>
    <ul>
      <li>Too early: 1:00-1:20</li>
      <li>About right: 1:30-1:45</li>
      <li>Too late: 1:50-2:00</li>
    </ul>
  </solution>


<!-- ============================================================== 
   Notas profesor <prelude> (se pueden mostrar previo al enunciado)                      
===================================================================  -->
<prelude component="profesor"> 

  <!-- Estándares CCSS asociados -->
  <paragraphs>
    <title><custom ref="ccss-actividad-titulo"/></title> 
    <ul>
      <li> 
        <custom ref="ccss-addressing"/>
        <xref ref="ccss-3-MD-A-1" text="custom">3.MD.A.1</xref>
      </li>
    </ul>
  </paragraphs>

  <!-- Tiempo recomendado -->
  <paragraphs>
    <title><custom ref="recommended-time-titulo"/></title>
    <p>10 minutos</p>
  </paragraphs>

  <!-- Introducción de la actividad -->  
  <paragraphs>
    <title><custom ref="narrative-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <p>The purpose of this Estimation Exploration is for students to make sense of times that would be reasonable with only the hour hand as a reference on a clock.</p>
  </paragraphs>

  <!-- Launch -->
  <paragraphs>
    <title><custom ref="launch-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>Groups of 2</li>
      <li>Display image.</li>
      <li>
        <q>¿Qué estimación sería muy tarde?, ¿muy temprano?, ¿razonable?</q>
      </li>
      <li>1 minute: quiet think time</li>
    </ul>
  </paragraphs>

  <!-- Instrucciones para el desarrollo de la actividad -->
  <paragraphs>
    <title><custom ref="instructions-teacher-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>
        <q>Discutan con su compañero cómo pensaron</q>
      </li>
      <li>1 minute: partner discussion</li>
      <li>Record responses.</li>
    </ul>
  </paragraphs>

</prelude>


<!-- ============================================================== 
   Notas profesor <postlude> (se pueden mostrar después del enunciado)                      
===================================================================  -->
<postlude component="profesor">

  <!-- Síntesis de la actividad -->
  <paragraphs>
    <title><custom ref="synthesis-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>
        <q>¿Cómo supieron que la hora era la 1?</q> (The hour hand passes between 1 and 2 as the time goes from 1:00 to 2:00.)
      </li>
      <li><p>Consider asking:</p>
        <ul>
          <li><q>¿Cómo decidieron cuánto tiempo había pasado desde la 1:00?</q> (It has to be a little past 1:30 since the hour hand is a little more than halfway between the 1 and the 2.)</li>
        </ul>
      </li>
    </ul>
  </paragraphs>

</postlude>

</exploration>