<?xml version='1.0' encoding='utf-8'?>

<!-- ====================================================================== 
   El calentamiento es un <exploration> (distinto a las otras actividades)
   Para RRRRR usar el estilo del calentamiento. Por ejemplo, usar 
   RRRRRR=observa con los "Observa y Pregúntate"
===========================================================================  -->
<exploration xml:id="warm-exploracionDeEstimacion-medirEnPulgadas" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>Exploración de estimación: Midamos en pulgadas</title>

<statement>
  <p>¿Cuál es la longitud del clip?</p>
  <image source="jpg-source/3.6.A2 Warmup.jpg">
   <shortdescription>clip de un poco más de una pulgada</shortdescription>
  </image>
  <p>Escribe una estimación que sea:</p>
  <tabular top="medium" halign="center" valign="middle">
    <row header="yes" left="medium" bottom="medium">
      <cell right="medium">muy baja</cell>
      <cell right="medium">razonable</cell>
      <cell right="medium">muy alta</cell>
    </row>
    <row left="minor" bottom="minor">
      <cell right="minor"><nbsp/></cell>
      <cell right="minor"><nbsp/></cell>
      <cell right="minor"><nbsp/></cell>    </row>    
  </tabular>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <p>Sample responses:</p>
    <ul>
      <li>Too low: <m>1\frac{1}{8}</m> inches or less</li>
      <li>About right: Between <m>1\frac{1}{6}</m> and <m>1\frac{1}{3}</m> inches</li>
      <li>Too high: <m>1\frac{1}{2}</m> inches or greater</li>
    </ul>
  </solution>


<!-- ============================================================== 
   Notas profesor <prelude> (se pueden mostrar previo al enunciado)                      
===================================================================  -->
<prelude component="profesor"> 

  <!-- Estándares CCSS asociados -->
  <paragraphs>
    <title><custom ref="ccss-actividad-titulo"/></title> 
    <ul>
      <li> 
        <custom ref="ccss-addressing"/>
        <xref ref="ccss-3-MD-B-4" text="custom">3.MD.B.4</xref>
      </li>
    </ul>
  </paragraphs>

  <!-- Tiempo recomendado -->
  <paragraphs>
    <title><custom ref="recommended-time-titulo"/></title>
    <p>10 minutos</p>
  </paragraphs>

  <!-- Introducción de la actividad -->  
  <paragraphs>
    <title><custom ref="narrative-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <p>The purpose of this Estimation Exploration is to practice the skill of estimating a reasonable answer based on experience and known information. The warm-up also draws students' attention to a length between a full inch and one-half of an inch, preparing students to work with such lengths later.</p>
  </paragraphs>

  <!-- Launch -->
  <paragraphs>
    <title><custom ref="launch-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>Groups of 2</li>
      <li>Display the image.</li>
      <li>
        <q>¿Qué estimación sería muy alta?, ¿muy baja?, ¿razonable?</q>
      </li>
      <li>1 minute: quiet think time</li>
    </ul>
  </paragraphs>

  <!-- Instrucciones para el desarrollo de la actividad -->
  <paragraphs>
    <title><custom ref="instructions-teacher-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>
        <q>Discutan con su pareja cómo pensaron</q>
      </li>
      <li>1 minute: partner discussion</li>
      <li>Record responses.</li>
    </ul>
  </paragraphs>

</prelude>


<!-- ============================================================== 
   Notas profesor <postlude> (se pueden mostrar después del enunciado)                      
===================================================================  -->
<postlude component="profesor">

  <!-- Síntesis de la actividad -->
  <paragraphs>
    <title><custom ref="synthesis-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li><p>Consider asking:</p>
        <ul>
          <li><q>¿Alguien hizo una estimación menor que <fillin/>? ¿Alguien hizo una estimación mayor que <fillin/>?</q></li>
          <li><q>Teniendo en cuenta esta discusión, ¿alguien quiere ajustar su estimación?</q></li>
        </ul>
      </li>
    </ul>
  </paragraphs>

</postlude>

</exploration>