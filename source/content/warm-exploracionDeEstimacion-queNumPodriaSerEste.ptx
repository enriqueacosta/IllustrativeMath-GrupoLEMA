<?xml version='1.0' encoding='utf-8'?>

<!-- ====================================================================== 
   El calentamiento es un <exploration> (distinto a las otras actividades)
   Para RRRRR usar el estilo del calentamiento. Por ejemplo, usar 
   RRRRRR=observa con los "Observa y Pregúntate"
===========================================================================  -->
<exploration xml:id="warm-exploracionDeEstimacion-queNumPodriaSerEste" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>[@@@@@@@@@]</title>

<statement>
  <p>[@@@@@@@@@]</p>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <p>Sample responses:</p>
<ul>
      <li>Too low: <m>&lt; 130</m></li>
      <li>About right: 130–140</li>
      <li>Too high: <m>&gt; 140</m></li>
    </ul>
  </solution>


<!-- ============================================================== 
   Notas profesor <prelude> (se pueden mostrar previo al enunciado)                      
===================================================================  -->
<prelude component="profesor"> 

  <!-- Estándares CCSS asociados -->
  <paragraphs>
    <title><custom ref="ccss-actividad-titulo"/></title> 
    <ul>
      <li> 
        <custom ref="ccss-addressing"/>
        [@@@@@@@@@]
        <!-- <xref ref="ccss-2-MD" text="custom">2.MD</xref>,  -->
        <!-- <xref ref="ccss-2-OA-C-4" text="custom">2.OA.C.4</xref> -->
      </li>
      <li>
        <custom ref="ccss-buildingOn"/>
        [@@@@@@@@@]
        <!-- <xref ref="ccss-2-MD" text="custom">2.MD</xref>,  -->
        <!-- <xref ref="ccss-2-OA-C-4" text="custom">2.OA.C.4</xref> -->
      </li>
      <li>
        <custom ref="ccss-buildingTowards"/>
        [@@@@@@@@@]
        <!-- <xref ref="ccss-2-MD" text="custom">2.MD</xref>,  -->
        <!-- <xref ref="ccss-2-OA-C-4" text="custom">2.OA.C.4</xref> -->
      </li>
    </ul>
  </paragraphs>

  <!-- Tiempo recomendado -->
  <paragraphs>
    <title><custom ref="recommended-time-titulo"/></title>
    <p>10 minutos</p>
  </paragraphs>

  <!-- Introducción de la actividad -->  
  <paragraphs>
    <title><custom ref="narrative-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <p>The purpose of this Estimation Exploration is for students to think about what value a point on the number line could represent. The only labeled tick marks are hundreds so students need to reason about what numbers are in between and how far the point is from the labeled numbers. </p>
  </paragraphs>

  <!-- Materiales requeridos de la actividad -->
  <paragraphs>
    <title><custom ref="materials-actividad-titulo"/></title>
    <p>[mmmmmmmmmm]</p>
    <!-- <xi:include href="./warm-exploracionDeEstimacion-queNumPodriaSerEste-mat.ptx"/>  -->
  </paragraphs>

  <!-- Launch -->
  <paragraphs>
    <title><custom ref="launch-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>Groups of 2</li>
      <li>Display the image.</li>
      <li>
        <q>¿Qué estimación sería muy alta?, ¿muy baja?, ¿razonable?</q>
      </li>
      <li>1 minute: quiet think time</li>
    </ul>
  </paragraphs>

  <!-- Instrucciones para el desarrollo de la actividad -->
  <paragraphs>
    <title><custom ref="instructions-teacher-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>
        <q>Discutan con su pareja cómo pensaron</q>
      </li>
      <li>1 minute: partner discussion</li>
      <li>Record responses.</li>
    </ul>
  </paragraphs>

</prelude>


<!-- ============================================================== 
   Notas profesor <postlude> (se pueden mostrar después del enunciado)                      
===================================================================  -->
<postlude component="profesor">

  <!-- Estrategias de apoyo para estudiantes con dificultades -->
  <paragraphs>
    <title><custom ref="support-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <p>=== NOT PRESENT ===</p>
  </paragraphs>

  <!-- Síntesis de la actividad -->
  <paragraphs>
    <title><custom ref="synthesis-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li><p>Consider asking:</p><ul>
<li>
<q>¿Alguien tiene una estimación menor que <fillin/>? ¿Alguien tiene una estimación mayor que <fillin/>?</q></li>
<li>
<q>Teniendo en cuenta esta discusión, ¿alguien quiere ajustar su estimación?</q></li>
</ul>
      </li>
      <li>
        <q>¿Qué nos ayudaría a estar más seguros de nuestra estimación?</q>  (More tick marks that are equally spaced. Marks of multiples of 10.)
      </li>
    </ul>
  </paragraphs>


  <!-- Descripción del desarrollo de lenguaje matemático -->
  <paragraphs>
    <title><custom ref="language-actividad-titulo"/></title>
    <p>[@@@@@@@@@]</p>
  </paragraphs>

  <!-- Estrategias de acceso para estudiantes con discapacidades -->
  <paragraphs>
    <title><custom ref="accesibility-actividad-titulo"/></title>
    <p>[@@@@@@@@@]</p>
  </paragraphs>

</postlude>

</exploration>