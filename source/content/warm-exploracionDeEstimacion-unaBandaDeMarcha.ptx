<!-- ====================================================================== 
   El calentamiento es un <exploration> (distinto a las otras actividades)
   Para RRRRR usar el estilo del calentamiento. Por ejemplo, usar 
   RRRRRR=observa con los "Observa y Pregúntate"
===========================================================================  -->
<exploration xml:id="warm-exploracionDeEstimacion-unaBandaDeMarcha" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>[@@@@@@@@@]</title>

<statement>
  <p>[@@@@@@@@@]</p>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <p>Sample responses:</p>
<ul>
      <li>Too low: <m>&lt; 140</m></li>
      <li>About right: 140–200</li>
      <li>Too high: <m>&gt; 200</m></li>
    </ul>
  </solution>


