<!-- ====================================================================== 
   El calentamiento es un <exploration> (distinto a las otras actividades)
   Para RRRRR usar el estilo del calentamiento. Por ejemplo, usar 
   RRRRRR=observa con los "Observa y Pregúntate"
===========================================================================  -->
<exploration xml:id="warm-observa-digitosQueDesaparecen" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>Observa y pregúntate: Dígitos que desaparecen</title>

<statement>
  <p>¿Qué observas? ¿Qué te preguntas?</p>
  <sidebyside>
    <image source="svg-source/tikz-file-148974">
      <shortdescription>descomposición en forma expandida</shortdescription>
    </image>
    <image source="svg-source/tikz-file-148975">
      <shortdescription>descomposición por valor posicional</shortdescription>
    </image>
  </sidebyside>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <p>Students may notice:</p>
    <ul>
      <li>On the left is 325 written in expanded form. On the right is 325 written the regular way.</li>
      <li>Parts of the expression on the left are crossed out. The first two digits in the number on the right are crossed out.</li>
      <li>Both the expression and the number 325 have smaller numbers or digits written above them.</li>
      <li>The expression on the left shows 120 and the number on the right shows 12 in the tens place.</li>
      <li>The expression on the left shows 200 and the number on the right shows 2 for the hundreds.</li>
      <li>Both the expression and the number shows a hundred decomposed into 10 tens and then added to the 2 tens that were already there.</li>
    </ul>
    <p>Students may wonder:</p>
    <ul>
      <li>Why are parts of the expression and the number crossed out?</li>
      <li>What do the little numbers and the little digits represent?</li>
      <li>Why would we write a number like shown on the right?</li>
      <li>How is this related to what we did yesterday?</li>
    </ul>
  </solution>


<!-- ============================================================== 
   Notas profesor <prelude> (se pueden mostrar previo al enunciado)                      
===================================================================  -->
<prelude component="profesor"> 

  <!-- Estándares CCSS asociados -->
  <paragraphs>
    <title><custom ref="ccss-actividad-titulo"/></title> 
    <ul>
      <li> 
        <custom ref="ccss-addressing"/>
        <xref ref="ccss-3-NBT-A-2" text="custom">3.NBT.A.2</xref>
      </li>  
    </ul>
  </paragraphs>

  <!-- Tiempo recomendado -->
  <paragraphs>
    <title><custom ref="recommended-time-titulo"/></title>
    <p>10 minutos</p>
  </paragraphs>

  <!-- Introducción de la actividad -->  
  <paragraphs>
    <title><custom ref="narrative-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <p>The purpose of this warm-up is to elicit the observation that a hundred that has been decomposed into more tens can be recorded using a condensed notation, which will be useful later in the lesson when students decompose hundreds and tens to facilitate subtraction. While students may notice and wonder many things about these numbers, how the decomposition is recorded is the important discussion point. Base-ten blocks or diagrams can be used during the discussion if students need additional support in making sense of the condensed notation.</p>
  </paragraphs>

  <!-- Materiales requeridos de la actividad -->
  <paragraphs>
    <title><custom ref="materials-actividad-titulo"/></title>
    <xi:include href="./warm-observa-digitosQueDesaparecen-mat.ptx"/>  
  </paragraphs>

  <!-- Launch -->
  <paragraphs>
    <title><custom ref="launch-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>Groups of 2</li>
      <li>Display the image.</li>
      <li>
        <q>¿Qué observan? ¿Qué se preguntan?</q>
      </li>
      <li>1 minute: quiet think time</li>
    </ul>
  </paragraphs>

  <!-- Instrucciones para el desarrollo de la actividad -->
  <paragraphs>
    <title><custom ref="instructions-teacher-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>
        <q>Discutan con su pareja lo que pensaron</q>
      </li>
      <li>1 minute: partner discussion</li>
      <li>Share and record responses.</li>
    </ul>
  </paragraphs>

</prelude>


<!-- ============================================================== 
   Notas profesor <postlude> (se pueden mostrar después del enunciado)                      
===================================================================  -->
<postlude component="profesor">

  <!-- Síntesis de la actividad -->
  <paragraphs>
    <title><custom ref="synthesis-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>
        <q>La expresión en forma desarrollada y el número muestran ambas una unidad en base diez que se está descomponiendo en unidades en base diez más pequeñas. ¿Dónde ven esto en cada caso?</q>  (The 300 has been turned into 200 in both examples. The 200 is shown with 200 in the first example, but just a 2 in the second example. The 2 tens has been turned into 12 tens in both examples. The 12 tens is shown as 120 in the first example, but just a 12 in the tens place in the second example.)
      </li>
    </ul>
  </paragraphs>

</postlude>

</exploration>