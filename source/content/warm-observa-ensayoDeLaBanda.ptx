  <!-- Tiempo recomendado -->
  <paragraphs>
    <title><custom ref="recommended-time-titulo"/></title>
    <p>10 minutos</p>
  </paragraphs>

  <!-- Introducción de la actividad -->  
  <paragraphs>
    <title><custom ref="narrative-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <p>The purpose of this warm-up is to elicit the idea that many different questions could be asked about this situation involving time, which will be useful when students solve problems in a later activity. </p>
  </paragraphs>

  <!-- Materiales requeridos de la actividad -->
  <paragraphs>
    <title><custom ref="materials-actividad-titulo"/></title>
    <p>[mmmmmmmmmm]</p>
    <!-- <xi:include href="./warm-observa-ensayoDeLaBanda-mat.ptx"/>  -->
  </paragraphs>

  <!-- Launch -->
  <paragraphs>
    <title><custom ref="launch-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>Groups of 2</li>
      <li>Display the situation.</li>
      <li>
        <q>¿Qué observan? ¿Qué se preguntan?</q>
      </li>
      <li>1 minute: quiet think time</li>
    </ul>
  </paragraphs>

  <!-- Instrucciones para el desarrollo de la actividad -->
  <paragraphs>
    <title><custom ref="instructions-teacher-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>
        <q>Discutan con su compañero lo que pensaron</q>
      </li>
      <li>1 minute: partner discussion</li>
      <li>Share and record responses.</li>
    </ul>
  </paragraphs>

</prelude>


<!-- ============================================================== 
   Notas profesor <postlude> (se pueden mostrar después del enunciado)                      
===================================================================  -->
<postlude component="profesor">

  <!-- Estrategias de apoyo para estudiantes con dificultades -->
  <paragraphs>
    <title><custom ref="support-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <p>=== NOT PRESENT ===</p>
  </paragraphs>

  <!-- Síntesis de la actividad -->
  <paragraphs>
    <title><custom ref="synthesis-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>
        <q>Agreguémosle tiempos a la situación de Han. ¿Qué tiempos podríamos agregar?</q>  (The time he started or finished dinner. The amount of time he was on the bus. How long he waited for the bus. The time his band practice started.)
      </li>
      <li>
        <q>¿Qué tipo de preguntas podríamos hacer sobre esta situación?</q>
      </li>
    </ul>
  </paragraphs>


  <!-- Descripción del desarrollo de lenguaje matemático -->
