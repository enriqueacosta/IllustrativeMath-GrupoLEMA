<!-- ====================================================================== 
   El calentamiento es un <exploration> (distinto a las otras actividades)
   Para RRRRR usar el estilo del calentamiento. Por ejemplo, usar 
   RRRRRR=observa con los "Observa y Pregúntate"
===========================================================================  -->
<exploration xml:id="warm-observa-laFeria" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>[@@@@@@@@@]</title>

<statement>
  <p>[@@@@@@@@@]</p>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <p>Students may notice:</p>
<ul>
      <li>There are rides.</li>
      <li>There are really big pumpkins.</li>
      <li>There are cows.</li>
      <li>It looks like a fair or a carnival.</li>
      <li>There are a lot of people walking around.</li>
    </ul>
<p>Students may wonder:</p>
<ul>
      <li>Why are we looking at these pictures?</li>
      <li>Why are those pumpkins so big?</li>
      <li>How much do those pumpkins weigh?</li>
      <li>How many different rides are there?</li>
    </ul>
  </solution>


