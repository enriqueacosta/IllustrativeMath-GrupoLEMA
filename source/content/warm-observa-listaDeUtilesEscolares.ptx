<?xml version='1.0' encoding='utf-8'?>

<!-- ====================================================================== 
   El calentamiento es un <exploration> (distinto a las otras actividades)
   Para RRRRR usar el estilo del calentamiento. Por ejemplo, usar 
   RRRRRR=observa con los "Observa y Pregúntate"
===========================================================================  -->
<exploration xml:id="warm-observa-listaDeUtilesEscolares" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>Observa y pregúntate: Lista de útiles escolares</title>

<statement>
  <p>¿Qué observas? ¿Qué te preguntas?</p>
  <sbsgroup widths="45% 45%">
    <sidebyside>
      <tabular top="medium" halign="center" valign="middle">
        <col width="80%"/>
        <col width="20%"/>
        <row header="yes" left="medium" bottom="medium">
          <cell right="medium">útiles de trabajo</cell>
          <cell right="medium">costo</cell>
        </row>
        <row left="minor" bottom="minor">
          <cell right="minor"><p>caja de 25 marcadores</p></cell>
          <cell right="minor">$5</cell>
        </row>
        <row left="minor" bottom="minor">
          <cell right="minor"><p>caja de 100 crayones</p></cell>
          <cell right="minor">$8</cell>
        </row>
      </tabular>
      <tabular top="medium" halign="center" valign="middle">
        <col width="80%"/>
        <col width="20%"/>
        <row header="yes" left="medium" bottom="medium">
          <cell right="medium"><p>biblioteca del salón</p></cell>
          <cell right="medium">costo</cell>
        </row>
        <row left="minor" bottom="minor">
          <cell right="minor"><p>colección de 20 libros de historia</p></cell>
          <cell right="minor">$250</cell>
        </row>
        <row left="minor" bottom="minor">
          <cell right="minor"><p>libro de cuentos (80 opciones)</p></cell>
          <cell right="minor">$8</cell>
        </row>
      </tabular>
    </sidebyside>
    <sidebyside>
      <tabular top="medium" halign="center" valign="middle">
        <col width="80%"/>
        <col width="20%"/>
        <row header="yes" left="medium" bottom="medium">
          <cell right="medium"><p>objetos especiales</p></cell>
          <cell right="medium">costo</cell>
        </row>
        <row left="minor" bottom="minor">
          <cell right="minor"><p>alfombra para el rincón de lectura</p></cell>
          <cell right="minor">$65</cell>
        </row>
        <row left="minor" bottom="minor">
          <cell right="minor"><p>acuario para la clase, con peces</p></cell>
          <cell right="minor">$159</cell>
        </row>
      </tabular>
      <tabular top="medium" halign="center" valign="middle">
        <col width="80%"/>
        <col width="20%"/>
        <row header="yes" left="medium" bottom="medium">
          <cell right="medium"><p>entretenimiento</p></cell>
          <cell right="medium">costo</cell>
        </row>
        <row left="minor" bottom="minor">
          <cell right="minor"><p>juegos de mesa (40 opciones)</p></cell>
          <cell right="minor">$15</cell>
        </row>
        <row left="minor" bottom="minor">
          <cell right="minor"><p>juegos interactivos de computadora (de matemáticas y de lectura)</p></cell>
          <cell right="minor">$75</cell>
        </row>
      </tabular>
    </sidebyside>
  </sbsgroup>
  
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <p>Students may notice:</p>
    <ul>
      <li>There are different categories.</li>
      <li>This looks like a list of school supplies.</li>
      <li>Some items are much more expensive than others.</li>
      <li>Some of the things have different options.</li>
    </ul>
    <p>Students may wonder:</p>
    <ul>
      <li>What kinds of story books are available?</li>
      <li>Why are some things much more expensive than others?</li>
      <li>How much does the whole list cost if we buy everything on it for our class?</li>
      <li>What board games are available?</li>
    </ul>
  </solution>


<!-- ============================================================== 
   Notas profesor <prelude> (se pueden mostrar previo al enunciado)                      
===================================================================  -->
<prelude component="profesor"> 

  <!-- Estándares CCSS asociados -->
  <paragraphs>
    <title><custom ref="ccss-actividad-titulo"/></title> 
    <ul>
      <li>
        <custom ref="ccss-buildingTowards"/>
        <xref ref="ccss-3-NBT-A-1" text="custom">3.NBT.A.1</xref>,
        <xref ref="ccss-3-NBT-A-2" text="custom">3.NBT.A.2</xref>
      </li>
    </ul>
  </paragraphs>

  <!-- Tiempo recomendado -->
  <paragraphs>
    <title><custom ref="recommended-time-titulo"/></title>
    <p>10 minutos</p>
  </paragraphs>

  <!-- Introducción de la actividad -->  
  <paragraphs>
    <title><custom ref="narrative-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <p>The purpose of this warm-up is to elicit observations about school supplies in different categories and with varying prices, familiarizing students with the context for upcoming work. While students may notice and wonder many things, focus the discussion on the large selection and wide range of prices.</p>
  </paragraphs>

  <!-- Launch -->
  <paragraphs>
    <title><custom ref="launch-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>Groups of 2</li>
      <li>Display the table.</li>
      <li>
        <q>¿Qué observan? ¿Qué se preguntan?</q>
      </li>
      <li>1 minute: quiet think time</li>
    </ul>
  </paragraphs>

  <!-- Instrucciones para el desarrollo de la actividad -->
  <paragraphs>
    <title><custom ref="instructions-teacher-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>
        <q>Discutan con su pareja lo que pensaron</q>
      </li>
      <li>1 minute: partner discussion</li>
      <li>Share and record responses.</li>
    </ul>
  </paragraphs>

</prelude>


<!-- ============================================================== 
   Notas profesor <postlude> (se pueden mostrar después del enunciado)                      
===================================================================  -->
<postlude component="profesor">

  <!-- Síntesis de la actividad -->
  <paragraphs>
    <title><custom ref="synthesis-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>
        <q>Si tuvieran que escoger un artículo de la lista para nuestro salón de clase, ¿cuál escogerían?</q>
      </li>
      <li>
        <q>¿Qué otra cosa que no esté en la lista les gustaría comprar para nuestro salón de clase?</q>
      </li>
      <li>30 seconds: quiet think time</li>
      <li>Share and record responses.</li>
    </ul>
  </paragraphs>

</postlude>

</exploration>