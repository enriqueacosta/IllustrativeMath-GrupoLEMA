<!-- ====================================================================== 
   El calentamiento es un <exploration> (distinto a las otras actividades)
   Para RRRRR usar el estilo del calentamiento. Por ejemplo, usar 
   RRRRRR=observa con los "Observa y Pregúntate"
===========================================================================  -->
<exploration xml:id="warm-queSabesSobre-lasPulgadas" xmlns:xi="http://www.w3.org/2001/XInclude"> 

<title>¿Qué sabes sobre las pulgadas?</title>

<statement>
  <p>¿Qué sabes sobre las pulgadas?</p>
</statement>

<solution>
    <p>[+++++++++++++++]</p>
    <p>Sample responses:</p>
    <ul>
      <li>They are used to measure length.</li>
      <li>There are inch marks on rulers, yardsticks, and tape measures.</li>
      <li>They are shorter than feet.</li>
      <li>They are longer than centimeters.</li>
    </ul>
  </solution>


<!-- ============================================================== 
   Notas profesor <prelude> (se pueden mostrar previo al enunciado)                      
===================================================================  -->
<prelude component="profesor"> 

  <!-- Estándares CCSS asociados -->
  <paragraphs>
    <title><custom ref="ccss-actividad-titulo"/></title> 
    <ul>
      <li>
        <custom ref="ccss-buildingTowards"/>
        <xref ref="ccss-3-MD-B-4" text="custom">3.MD.B.4</xref>
      </li>
    </ul>
  </paragraphs>

  <!-- Tiempo recomendado -->
  <paragraphs>
    <title><custom ref="recommended-time-titulo"/></title>
    <p>10 minutos</p>
  </paragraphs>

  <!-- Introducción de la actividad -->  
  <paragraphs>
    <title><custom ref="narrative-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <p>The purpose of this warm-up is to invite students to share what they know about inches. Later in the lesson, students will explore lengths that are not a whole-number of inches.</p>
  </paragraphs>

  <!-- Launch -->
  <paragraphs>
    <title><custom ref="launch-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>Display the question.</li>
      <li>
        <q>¿Qué saben sobre las pulgadas?</q>
      </li>
      <li>1 minute: quiet think time</li>
    </ul>
  </paragraphs>

  <!-- Instrucciones para el desarrollo de la actividad -->
  <paragraphs>
    <title><custom ref="instructions-teacher-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>Record responses.</li>
    </ul>
  </paragraphs>

</prelude>


<!-- ============================================================== 
   Notas profesor <postlude> (se pueden mostrar después del enunciado)                      
===================================================================  -->
<postlude component="profesor">

  <!-- Síntesis de la actividad -->
  <paragraphs>
    <title><custom ref="synthesis-actividad-titulo"/></title>
    <p>[+++++++++++++++]</p>
    <ul>
      <li>
        <q>Las pulgadas son una unidad que usamos para medir la longitud. ¿Qué longitudes podríamos medir en pulgadas?</q> (The length of a 
        shoe. The length of material for an art project. The height of a desk.)
      </li>
    </ul>
  </paragraphs>

</postlude>

</exploration>